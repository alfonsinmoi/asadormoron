<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Repartidores.GastoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Volver -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;"
                           FontSize="22"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Nota de Gasto"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Guardar -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Image Source="save.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CommandGuardar}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- ============================================ -->
                <!-- CARD: IMPORTE Y TIPO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">
                        <Label Text="Datos del gasto"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <!-- Importe -->
                            <StackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Importe"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"/>
                                <Border BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E0E0E0"
                                        Padding="14,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Entry Text="{Binding Precio}"
                                               FontFamily="Nunito_bold"
                                               FontSize="18"
                                               TextColor="{StaticResource RojoMarca}"
                                               BackgroundColor="Transparent"
                                               Keyboard="Numeric"
                                               HorizontalTextAlignment="End"
                                               Placeholder="0.00"/>
                                        <Label Grid.Column="1"
                                               Text="€"
                                               FontFamily="Nunito_bold"
                                               FontSize="18"
                                               TextColor="{StaticResource RojoMarca}"
                                               VerticalOptions="Center"
                                               Margin="4,0,0,0"/>
                                    </Grid>
                                </Border>
                            </StackLayout>

                            <!-- Tipo -->
                            <StackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Tipo"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"/>
                                <Border BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E0E0E0"
                                        Padding="14,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Picker ItemsSource="{Binding Tipo}"
                                            SelectedItem="{Binding TipoSeleccionado, Mode=TwoWay}"
                                            FontFamily="Nunito"
                                            FontSize="15"
                                            TextColor="{DynamicResource Negro}"
                                            Title="Seleccionar"/>
                                </Border>
                            </StackLayout>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: CONCEPTO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">
                        <Label Text="Concepto"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <Border BackgroundColor="#FAFAFA"
                                StrokeThickness="1"
                                Stroke="#E0E0E0"
                                Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding Concepto}"
                                    FontFamily="Nunito"
                                    FontSize="15"
                                    TextColor="{DynamicResource Negro}"
                                    BackgroundColor="Transparent"
                                    Placeholder="Describe el concepto del gasto..."
                                    HeightRequest="120"
                                    AutoSize="TextChanges"/>
                        </Border>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- BOTÓN GUARDAR -->
                <!-- ============================================ -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        Padding="18"
                        Margin="0,8,0,0"
                        HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" HorizontalOptions="Center">
                        <Image Grid.Column="0"
                               Source="save.png"
                               WidthRequest="22"
                               HeightRequest="22"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Guardar Gasto"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CommandGuardar}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Espaciado final -->
                <BoxView HeightRequest="20" Color="Transparent"/>

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
