<?xml version="1.0" encoding="utf-8" ?>
<popup:PopupPage
    x:Class="AsadorMoron.Views.Repartidores.PopupPageInfoRepartidor"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:popup="clr-namespace:Mopups.Pages;assembly=Mopups"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    x:Name="PopupRep"
    BackgroundColor="#80000000">

    <popup:PopupPage.Content>
        <Border Margin="24"
                BackgroundColor="White"
                StrokeThickness="0"
                MaximumWidthRequest="420"
                MaximumHeightRequest="650"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.3"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*" Padding="0">

                <!-- HEADER CON FOTO -->
                <Border Grid.Row="0"
                        BackgroundColor="#C41E3A"
                        StrokeThickness="0"
                        Padding="20,20,20,24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24,24,0,0"/>
                    </Border.StrokeShape>

                    <StackLayout Spacing="12" HorizontalOptions="Center">
                        <!-- Foto del repartidor -->
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                WidthRequest="80"
                                HeightRequest="80"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="40"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.2"/>
                            </Border.Shadow>
                            <ff:CachedImage x:Name="pbFoto"
                                            Aspect="AspectFill"
                                            HeightRequest="76"
                                            WidthRequest="76"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                <ff:CachedImage.Clip>
                                    <EllipseGeometry Center="38,38" RadiusX="38" RadiusY="38"/>
                                </ff:CachedImage.Clip>
                            </ff:CachedImage>
                        </Border>

                        <Label Text="Repartidor"
                               FontFamily="Nunito_bold"
                               FontSize="20"
                               TextColor="White"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>

                <!-- CONTENIDO SCROLLABLE -->
                <ScrollView Grid.Row="1">
                    <StackLayout Padding="16" Spacing="12">

                        <!-- Nombre -->
                        <Border BackgroundColor="#F5F5F5"
                                StrokeThickness="0"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border BackgroundColor="#C41E3A"
                                        StrokeThickness="0"
                                        WidthRequest="36"
                                        HeightRequest="36">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Label Text="&#x1F464;"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Nombre"
                                           FontFamily="Nunito"
                                           FontSize="11"
                                           TextColor="#888888"/>
                                    <Label x:Name="txtNombre"
                                           FontFamily="Nunito_bold"
                                           FontSize="14"
                                           TextColor="#333333"/>
                                </StackLayout>
                            </Grid>
                        </Border>

                        <!-- Teléfono -->
                        <Border BackgroundColor="#F5F5F5"
                                StrokeThickness="0"
                                Padding="14,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Border BackgroundColor="#C41E3A"
                                        StrokeThickness="0"
                                        WidthRequest="36"
                                        HeightRequest="36">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Label Text="&#x1F4DE;"
                                           FontSize="18"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Teléfono"
                                           FontFamily="Nunito"
                                           FontSize="11"
                                           TextColor="#888888"/>
                                    <Label x:Name="txtTelefono"
                                           FontFamily="Nunito_bold"
                                           FontSize="14"
                                           TextColor="#333333"/>
                                </StackLayout>
                            </Grid>
                        </Border>

                        <!-- SECCIÓN MENSAJES -->
                        <Border BackgroundColor="#E3F2FD"
                                StrokeThickness="0"
                                Padding="12"
                                Margin="0,8,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label Text="&#x1F4AC; MENSAJES"
                                   FontFamily="Nunito_bold"
                                   FontSize="12"
                                   TextColor="#333333"/>
                        </Border>

                        <!-- Editor mensaje -->
                        <Border BackgroundColor="White"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor x:Name="txtMensaje"
                                    FontFamily="Nunito"
                                    FontSize="14"
                                    HeightRequest="70"
                                    TextColor="#333333"
                                    MaxLength="100"
                                    Placeholder="Escribir mensaje..."
                                    PlaceholderColor="#AAAAAA"/>
                        </Border>

                        <!-- Botón enviar -->
                        <Button Text="&#x1F4E4; Enviar Mensaje"
                                FontFamily="Nunito_bold"
                                FontSize="14"
                                BackgroundColor="#C41E3A"
                                TextColor="White"
                                CornerRadius="12"
                                HeightRequest="48"
                                Padding="20,0"
                                HorizontalOptions="End"
                                Clicked="Button_Clicked"/>

                        <!-- Lista de mensajes -->
                        <ListView x:Name="lista"
                                  BackgroundColor="Transparent"
                                  HasUnevenRows="True"
                                  SeparatorVisibility="None"
                                  VerticalScrollBarVisibility="Default">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <Border BackgroundColor="White"
                                                StrokeThickness="0"
                                                Margin="0,0,0,8"
                                                Padding="14,12">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="#000000" Offset="0,1" Radius="4" Opacity="0.06"/>
                                            </Border.Shadow>

                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackLayout Spacing="4" VerticalOptions="Center">
                                                    <!-- Mensaje -->
                                                    <Label Text="{Binding mensaje}"
                                                           FontFamily="Nunito"
                                                           FontSize="14"
                                                           TextColor="#333333"
                                                           LineBreakMode="WordWrap"/>
                                                    <!-- Fecha -->
                                                    <Label Text="{Binding fechaEnvio}"
                                                           FontFamily="Nunito"
                                                           FontSize="11"
                                                           TextColor="#888888"/>
                                                </StackLayout>

                                                <!-- Estado de respuesta -->
                                                <StackLayout Grid.Column="1"
                                                             IsVisible="{Binding contestado}"
                                                             VerticalOptions="Center">
                                                    <Border BackgroundColor="#E8F5E9"
                                                            StrokeThickness="0"
                                                            WidthRequest="36"
                                                            HeightRequest="36"
                                                            IsVisible="{Binding ok}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="18"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="&#x2705;"
                                                               FontSize="18"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"/>
                                                    </Border>
                                                    <Border BackgroundColor="#FFEBEE"
                                                            StrokeThickness="0"
                                                            WidthRequest="36"
                                                            HeightRequest="36"
                                                            IsVisible="{Binding ok, Converter={StaticResource InverseBoolConverter}}">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="18"/>
                                                        </Border.StrokeShape>
                                                        <Label Text="&#x274C;"
                                                               FontSize="18"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center"/>
                                                    </Border>
                                                </StackLayout>
                                            </Grid>
                                        </Border>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                    </StackLayout>
                </ScrollView>

            </Grid>
        </Border>
    </popup:PopupPage.Content>
</popup:PopupPage>
