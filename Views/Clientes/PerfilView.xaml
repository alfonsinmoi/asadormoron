<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.PerfilView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    x:Name="PerfilUsuario"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <StackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="2">
                    <Label Text="Mi Perfil"
                           FontFamily="Nunito_bold"
                           FontSize="18"
                           TextColor="#333333"
                           HorizontalOptions="Center"/>
                    <Label Text="Datos personales"
                           FontFamily="Nunito"
                           FontSize="12"
                           TextColor="#888888"
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Espacio -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>
            </Grid>
        </Border>

        <!-- CONTENIDO SCROLLEABLE -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- CARD: Avatar y Nombre -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#40C41E3A" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                        <!-- Avatar -->
                        <Border StrokeThickness="3"
                                Stroke="White"
                                WidthRequest="90"
                                HeightRequest="90"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="45"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CmdCambiaImagen}"/>
                            </Border.GestureRecognizers>
                            <ff:CachedImage Aspect="AspectFill"
                                            Source="{Binding Imagen}"
                                            WidthRequest="84"
                                            HeightRequest="84"/>
                        </Border>

                        <!-- Info -->
                        <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                            <Label Text="{Binding Nombre}"
                                   FontFamily="Nunito_bold"
                                   FontSize="22"
                                   TextColor="White"/>
                            <Label Text="{Binding Apellidos}"
                                   FontFamily="Nunito"
                                   FontSize="16"
                                   TextColor="#FFFFFFCC"/>
                            <StackLayout Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                <Border BackgroundColor="#FFFFFF30"
                                        StrokeThickness="0"
                                        Padding="10,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding FechaAlta, StringFormat='Desde {0:dd/MM/yyyy}'}"
                                           FontFamily="Nunito"
                                           FontSize="11"
                                           TextColor="Black"/>
                                </Border>
                            </StackLayout>
                        </StackLayout>
                    </Grid>
                </Border>

                <!-- CARD: Ubicación -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>

                    <StackLayout Spacing="16">
                        <!-- Header -->
                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Border BackgroundColor="{StaticResource RojoMarca}"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4CD;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Ubicación"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="#333333"
                                   VerticalOptions="Center"/>
                        </StackLayout>

                        <!-- Provincia -->
                        <StackLayout Spacing="6">
                            <Label Text="Provincia"
                                   FontFamily="Nunito_bold"
                                   FontSize="12"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E8E8E8"
                                    Padding="12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Picker Title="Selecciona Provincia"
                                        ItemsSource="{Binding Provincias}"
                                        SelectedItem="{Binding Provincia}"
                                        TextColor="#333333"
                                        FontFamily="Nunito"/>
                            </Border>
                        </StackLayout>

                        <!-- Población y Código Postal -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackLayout Spacing="6">
                                <Label Text="Población"
                                       FontFamily="Nunito_bold"
                                       FontSize="12"
                                       TextColor="#888888"/>
                                <Border BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E8E8E8"
                                        Padding="12,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Picker Title="Población"
                                            ItemsSource="{Binding Pueblos}"
                                            SelectedItem="{Binding Poblacion}"
                                            TextColor="#333333"
                                            FontFamily="Nunito"/>
                                </Border>
                            </StackLayout>

                            <StackLayout Grid.Column="1" Spacing="6">
                                <Label Text="Código Postal"
                                       FontFamily="Nunito_bold"
                                       FontSize="12"
                                       TextColor="#888888"/>
                                <Border BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E8E8E8"
                                        Padding="12,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Picker Title="C.P."
                                            ItemsSource="{Binding CodPostales}"
                                            ItemDisplayBinding="{Binding codPostal}"
                                            SelectedItem="{Binding CodPostal}"
                                            TextColor="#333333"
                                            FontFamily="Nunito"/>
                                </Border>
                            </StackLayout>
                        </Grid>

                        <!-- Dirección -->
                        <StackLayout Spacing="6">
                            <Label Text="Dirección"
                                   FontFamily="Nunito_bold"
                                   FontSize="12"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E8E8E8"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Placeholder="Tu dirección"
                                       Text="{Binding Direccion}"
                                       TextColor="#333333"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="12,0"/>
                            </Border>
                        </StackLayout>

                        <!-- Zona -->
                        <StackLayout Spacing="6">
                            <Label Text="Zona"
                                   FontFamily="Nunito_bold"
                                   FontSize="12"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E8E8E8"
                                    Padding="12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Picker Title="Selecciona Zona"
                                        ItemsSource="{Binding Zonas}"
                                        ItemDisplayBinding="{Binding nombre}"
                                        SelectedItem="{Binding Zona}"
                                        TextColor="#333333"
                                        FontFamily="Nunito"/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- CARD: Contacto -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>

                    <StackLayout Spacing="16">
                        <!-- Header -->
                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Border BackgroundColor="{StaticResource RojoMarca}"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4DE;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Contacto"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="#333333"
                                   VerticalOptions="Center"/>
                        </StackLayout>

                        <!-- Teléfono -->
                        <StackLayout Spacing="6">
                            <Label Text="Teléfono"
                                   FontFamily="Nunito_bold"
                                   FontSize="12"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E8E8E8"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Placeholder="Tu teléfono"
                                       Text="{Binding Telefono}"
                                       Keyboard="Telephone"
                                       TextColor="#333333"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       BackgroundColor="Transparent"
                                       Margin="12,0"/>
                            </Border>
                        </StackLayout>

                        <!-- Email (solo lectura) -->
                        <StackLayout Spacing="6">
                            <Label Text="Email"
                                   FontFamily="Nunito_bold"
                                   FontSize="12"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F0F0F0"
                                    StrokeThickness="0"
                                    Padding="12,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Email}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="#666666"/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- BOTONES DE ACCIÓN -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Guardar -->
                    <Border BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="52">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CommandGuardar}"/>
                        </Border.GestureRecognizers>
                        <StackLayout Orientation="Horizontal"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="8">
                            <Label Text="&#x2714;"
                                   FontSize="16"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <Label Text="Guardar"
                                   FontFamily="Nunito_bold"
                                   FontSize="15"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                        </StackLayout>
                    </Border>

                    <!-- Cancelar -->
                    <Border Grid.Column="1"
                            BackgroundColor="#333333"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="52">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CommandCancelar}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontFamily="Nunito_bold"
                               FontSize="15"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Botón Eliminar Cuenta -->
                <Border BackgroundColor="#FFEBEE"
                        StrokeThickness="1"
                        Stroke="#FFCDD2"
                        Padding="0"
                        HeightRequest="52"
                        Margin="0,0,0,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CommandEliminar}"/>
                    </Border.GestureRecognizers>
                    <StackLayout Orientation="Horizontal"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="8">
                        <Label Text="&#x26A0;"
                               FontSize="16"
                               TextColor="#C41E3A"
                               VerticalOptions="Center"/>
                        <Label Text="Eliminar Cuenta"
                               FontFamily="Nunito_bold"
                               FontSize="15"
                               TextColor="#C41E3A"
                               VerticalOptions="Center"/>
                    </StackLayout>
                </Border>

            </StackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
