<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.DetalleArticulosView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:badge="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:templates="clr-namespace:AsadorMoron.Views.Templates"
    x:Name="ViewDetalleArticulos"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título + Chip de Puntos -->
                <StackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="4">
                    <Label Text="{Binding Articulo.nombre}"
                           FontFamily="Nunito_bold"
                           FontSize="16"
                           TextColor="#333333"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"/>
                    <!-- Chip de puntos compacto -->
                    <Border IsVisible="{Binding SistemaPuntos}"
                            BackgroundColor="{DynamicResource Amarillo}"
                            StrokeThickness="0"
                            Padding="10,4"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <StackLayout Orientation="Horizontal" Spacing="4">
                            <Label Text="&#x2B50;" FontSize="10" VerticalOptions="Center"/>
                            <Label Text="{Binding Puntos, StringFormat='{0} pts'}"
                                   TextColor="{DynamicResource Negro}"
                                   FontFamily="Nunito_bold"
                                   FontSize="11"
                                   VerticalOptions="Center"/>
                        </StackLayout>
                    </Border>
                </StackLayout>

                <!-- Carrito con Badge -->
                <Grid Grid.Column="2" WidthRequest="48" HeightRequest="48">
                    <Border BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            Padding="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Image Source="carrito.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" HorizontalOptions="Center"/>
                    </Border>
                    <Border BackgroundColor="{DynamicResource Amarillo}"
                            StrokeThickness="0"
                            WidthRequest="22"
                            HeightRequest="22"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,-4,-4,0"
                            IsVisible="{Binding Cantidad, Converter={StaticResource StringEmptyToBooleanConverter}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="11"/>
                        </Border.StrokeShape>
                        <Label Text="{Binding Cantidad}"
                               FontSize="11"
                               FontFamily="Nunito_bold"
                               TextColor="{DynamicResource Negro}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrDetallePedidoCommand}"/>
                    </Grid.GestureRecognizers>
                </Grid>
            </Grid>
        </Border>

        <!-- CONTENIDO SCROLLEABLE -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="12">

                <!-- CARD: Imagen del producto -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid RowDefinitions="180,Auto">
                        <!-- Imagen -->
                        <Border Grid.Row="0" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20,20,0,0"/>
                            </Border.StrokeShape>
                            <Image Aspect="AspectFill"
                                   Source="{Binding Articulo.imagen}"
                                   VerticalOptions="FillAndExpand"
                                   HorizontalOptions="FillAndExpand"/>
                        </Border>
                        <!-- Info -->
                        <StackLayout Grid.Row="1" Padding="16,12" Spacing="4">
                            <Label FontFamily="Nunito_bold"
                                   FontSize="20"
                                   Text="{Binding Articulo.nombre}"
                                   TextColor="#333333"/>
                            <Label FontFamily="Nunito"
                                   FontSize="14"
                                   Text="{Binding Articulo.descripcion}"
                                   TextColor="#666666"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>
                    </Grid>
                </Border>

                <!-- CARD: OPCIONES (cuando no es combo) -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        IsVisible="{Binding TieneOpciones}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <!-- Header Opciones -->
                        <StackLayout IsVisible="{Binding Combo, Converter={StaticResource InverseBoolConverter}}" Spacing="10">
                            <StackLayout Orientation="Horizontal" Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}"
                                        StrokeThickness="0"
                                        Padding="10,6">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="OPCIONES"
                                           FontFamily="Nunito_bold"
                                           FontSize="12"
                                           TextColor="White"/>
                                </Border>
                                <Label Text="Seleccione una"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"
                                       VerticalOptions="Center"/>
                            </StackLayout>

                            <!-- Lista de Opciones -->
                            <StackLayout BindableLayout.ItemsSource="{Binding OpcionesLista}" Spacing="6">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,10">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <CheckBox VerticalOptions="Center"
                                                          IsChecked="{Binding seleccionado}"
                                                          Color="{DynamicResource Rojo}"
                                                          CheckedChanged="CheckBox_CheckedChanged"
                                                          AutomationId="{Binding id}"/>
                                                <Label Grid.Column="1"
                                                       FontFamily="Nunito"
                                                       FontSize="15"
                                                       Text="{Binding opcion}"
                                                       TextColor="#333333"
                                                       VerticalOptions="Center"/>
                                                <Label Grid.Column="2"
                                                       FontFamily="Nunito_bold"
                                                       FontSize="14"
                                                       IsVisible="{Binding visiblePuntos, Converter={StaticResource InverseBoolConverter}}"
                                                       Text="{Binding precio, StringFormat='{0:N2} €'}"
                                                       TextColor="{DynamicResource Rojo}"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </StackLayout>

                        <!-- COMBOS (múltiples secciones) -->
                        <StackLayout IsVisible="{Binding Combo}" Spacing="16">
                            <!-- Combo 1: Entrantes -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="1. ENTRANTES" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo1}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 2 -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="2. PRIMER PLATO 1" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo2}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 3 -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="3. PRIMER PLATO 2" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo3}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 4 -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="4. SEGUNDO PLATO 1" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo4}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 5 -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="5. SEGUNDO PLATO 2" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo5}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 6: Bebida -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="6. BEBIDA" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo6}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 7: Postre 1 -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="7. POSTRE 1" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo7}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>

                            <!-- Combo 8: Postre 2 -->
                            <StackLayout Spacing="8">
                                <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="8. POSTRE 2" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                                </Border>
                                <StackLayout BindableLayout.ItemsSource="{Binding Combo8}" Spacing="4">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <CheckBox IsChecked="{Binding Seleccionado}" Color="{DynamicResource Rojo}" CheckedChanged="CheckBox_CheckedChanged" AutomationId="{Binding id}"/>
                                                    <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- CARD: CANTIDAD (Modo Tienda) -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        IsVisible="{Binding ModoTienda}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="CANTIDAD" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </Border>
                        </StackLayout>
                        <Border BackgroundColor="#F5F5F5" StrokeThickness="0" Padding="8" HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="44,60,44" ColumnSpacing="4">
                                <Border Grid.Column="0"
                                        BackgroundColor="White"
                                        StrokeThickness="0"
                                        HeightRequest="44"
                                        WidthRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Path=BindingContext.ClickMenosCommand, Source={x:Reference Name=ViewDetalleArticulos}}" CommandParameter="{Binding id}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="−" FontSize="24" FontFamily="Nunito_bold" TextColor="{DynamicResource Rojo}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1"
                                       FontFamily="Nunito_bold"
                                       FontSize="20"
                                       HorizontalTextAlignment="Center"
                                       Text="{Binding CantidadOpcion, Mode=TwoWay}"
                                       TextColor="#333333"
                                       VerticalTextAlignment="Center"/>
                                <Border Grid.Column="2"
                                        BackgroundColor="{DynamicResource Rojo}"
                                        StrokeThickness="0"
                                        HeightRequest="44"
                                        WidthRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Path=BindingContext.ClickMasCommand, Source={x:Reference Name=ViewDetalleArticulos}}" CommandParameter="{Binding id}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="+" FontSize="24" FontFamily="Nunito_bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackLayout>
                </Border>

                <!-- CARD: INGREDIENTES/EXTRAS -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        IsVisible="{Binding TieneIngredientes}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Border BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding TextoIngredientes}" FontFamily="Nunito_bold" FontSize="12" TextColor="White" TextTransform="Uppercase"/>
                        </Border>
                        <StackLayout BindableLayout.ItemsSource="{Binding ListadoIngredientes}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackLayout Spacing="2" VerticalOptions="Center">
                                                <Label FontFamily="Nunito_bold" FontSize="14" Text="{Binding nombre}" TextColor="#333333"/>
                                                <Label FontFamily="Nunito" FontSize="13" Text="{Binding precio, StringFormat='{0:N2} €'}" TextColor="{DynamicResource Rojo}"/>
                                            </StackLayout>
                                            <Border Grid.Column="1" BackgroundColor="#EEEEEE" StrokeThickness="0" Padding="4" VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="36,36,36" ColumnSpacing="2">
                                                    <Border Grid.Column="0" BackgroundColor="White" StrokeThickness="0" HeightRequest="36" WidthRequest="36">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8"/>
                                                        </Border.StrokeShape>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Path=BindingContext.ClickMenosIngCommand, Source={x:Reference Name=ViewDetalleArticulos}}" CommandParameter="{Binding idIngrediente}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="−" FontSize="18" TextColor="{DynamicResource Rojo}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Label Grid.Column="1"
                                                           FontFamily="Nunito_bold"
                                                           FontSize="14"
                                                           HorizontalTextAlignment="Center"
                                                           Text="{Binding Cantidad, Mode=TwoWay}"
                                                           TextColor="#333333"
                                                           VerticalTextAlignment="Center"/>
                                                    <Border Grid.Column="2" BackgroundColor="{DynamicResource Rojo}" StrokeThickness="0" HeightRequest="36" WidthRequest="36">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8"/>
                                                        </Border.StrokeShape>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Path=BindingContext.ClickMasIngCommand, Source={x:Reference Name=ViewDetalleArticulos}}" CommandParameter="{Binding idIngrediente}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="+" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- CARD: ALÉRGENOS -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        IsVisible="{Binding TieneAlergenos}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Border BackgroundColor="#FF9800" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <StackLayout Orientation="Horizontal" Spacing="6">
                                <Label Text="&#x26A0;" FontSize="12" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="ALÉRGENOS" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </StackLayout>
                        </Border>
                        <FlexLayout x:Name="HLAlergenos"
                                    BindableLayout.ItemsSource="{Binding AlergenosLista}"
                                    Direction="Row"
                                    JustifyContent="Start"
                                    Wrap="Wrap">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <templates:AlergenosItemTemplate/>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </StackLayout>
                </Border>

                <!-- CARD: COMENTARIO -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        Margin="0,0,0,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Border BackgroundColor="#607D8B" StrokeThickness="0" Padding="10,6" HorizontalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <StackLayout Orientation="Horizontal" Spacing="6">
                                <Label Text="&#x270E;" FontSize="12" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="COMENTARIO" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </StackLayout>
                        </Border>
                        <Border StrokeThickness="1" Stroke="#E8E8E8" BackgroundColor="#FAFAFA" Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding Comentario}"
                                    HeightRequest="80"
                                    Placeholder="Escribe aquí tus comentarios..."
                                    PlaceholderColor="#AAAAAA"
                                    BackgroundColor="Transparent"
                                    TextColor="#333333"
                                    FontFamily="Nunito"/>
                        </Border>
                    </StackLayout>
                </Border>
            </StackLayout>
        </ScrollView>

        <!-- BOTÓN AÑADIR FLOTANTE -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,20">
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <!-- Botón Normal (Modo Tienda) -->
                <Button Grid.ColumnSpan="2"
                        BackgroundColor="{DynamicResource Rojo}"
                        Command="{Binding cmdActualizarCaja}"
                        CornerRadius="16"
                        FontFamily="Nunito_bold"
                        FontSize="16"
                        HeightRequest="52"
                        HorizontalOptions="FillAndExpand"
                        IsVisible="{Binding Path=BindingContext.ModoTienda, Source={x:Reference Name=ViewDetalleArticulos}}"
                        Text="{Binding TextoCaja}"
                        TextColor="White"/>
                <!-- Botón Puntos -->
                <Button Grid.ColumnSpan="2"
                        BackgroundColor="{DynamicResource Rojo}"
                        Command="{Binding cmdActualizarCajaPuntos}"
                        CornerRadius="16"
                        FontFamily="Nunito_bold"
                        FontSize="16"
                        HeightRequest="52"
                        HorizontalOptions="FillAndExpand"
                        IsVisible="{Binding Path=BindingContext.VisiblePuntos, Source={x:Reference Name=ViewDetalleArticulos}}"
                        Text="{Binding TextoCajaPuntos}"
                        TextColor="White"/>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
