<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.QuienView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ContactoView"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <StackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="2">
                    <Label Text="Contacto"
                           FontFamily="Nunito_bold"
                           FontSize="18"
                           TextColor="#333333"
                           HorizontalOptions="Center"/>
                    <Label Text="Estamos para ayudarte"
                           FontFamily="Nunito"
                           FontSize="12"
                           TextColor="#888888"
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Espacio -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>
            </Grid>
        </Border>

        <!-- CONTENIDO SCROLLEABLE -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- CARD: Logo e Información -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>

                    <StackLayout Spacing="16" HorizontalOptions="Center">
                        <!-- Logo -->
                        <Image Source="logo_morado.png"
                               HeightRequest="80"
                               Aspect="AspectFit"
                               BackgroundColor="Transparent"
                               HorizontalOptions="Center"/>

                        <!-- Texto informativo -->
                        <Label Text="Si tiene algún problema con su pedido, con la app o necesita cualquier tipo de información."
                               FontFamily="Nunito"
                               FontSize="14"
                               TextColor="#666666"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>

                        <Label Text="Llámanos o escríbenos"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               TextColor="#333333"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="Nos pondremos en contacto contigo a la mayor brevedad posible"
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>
                    </StackLayout>
                </Border>

                <!-- CARD: Opciones de Contacto -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>

                    <StackLayout Spacing="12">
                        <!-- Header -->
                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Border BackgroundColor="{StaticResource RojoMarca}"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4DE;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Contactar"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="#333333"
                                   VerticalOptions="Center"/>
                        </StackLayout>

                        <!-- Teléfono -->
                        <Border BackgroundColor="#FFF5F5"
                                StrokeThickness="0"
                                Padding="16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Telefono}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <Border BackgroundColor="{StaticResource RojoMarca}"
                                        StrokeThickness="0"
                                        WidthRequest="50"
                                        HeightRequest="50">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14"/>
                                    </Border.StrokeShape>
                                    <Image Source="telefono.png"
                                           WidthRequest="24"
                                           HeightRequest="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Teléfono"
                                           FontFamily="Nunito"
                                           FontSize="12"
                                           TextColor="#888888"/>
                                    <Label Text="{Binding NumTelefono}"
                                           FontFamily="Nunito_bold"
                                           FontSize="18"
                                           TextColor="#333333"/>
                                </StackLayout>
                                <Label Grid.Column="2"
                                       Text="&#x2192;"
                                       FontSize="20"
                                       TextColor="{StaticResource RojoMarca}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- WhatsApp -->
                        <Border BackgroundColor="#E8F5E9"
                                StrokeThickness="0"
                                Padding="16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding WhatsApp}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <Border BackgroundColor="#25D366"
                                        StrokeThickness="0"
                                        WidthRequest="50"
                                        HeightRequest="50">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14"/>
                                    </Border.StrokeShape>
                                    <Image Source="whatsapp.png"
                                           WidthRequest="24"
                                           HeightRequest="24"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                                <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="WhatsApp"
                                           FontFamily="Nunito"
                                           FontSize="12"
                                           TextColor="#888888"/>
                                    <Label Text="{Binding NumWhatsApp}"
                                           FontFamily="Nunito_bold"
                                           FontSize="18"
                                           TextColor="#333333"/>
                                </StackLayout>
                                <Label Grid.Column="2"
                                       Text="&#x2192;"
                                       FontSize="20"
                                       TextColor="#25D366"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </StackLayout>
                </Border>

                <!-- CARD: Enviar Mensaje -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        Margin="0,0,0,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>

                    <StackLayout Spacing="12">
                        <!-- Header -->
                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Border BackgroundColor="#607D8B"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x2709;"
                                       FontSize="18"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Enviar mensaje"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="#333333"
                                   VerticalOptions="Center"/>
                        </StackLayout>

                        <!-- Editor -->
                        <Border StrokeThickness="1"
                                Stroke="#E8E8E8"
                                BackgroundColor="#FAFAFA"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding Cuerpo}"
                                    HeightRequest="100"
                                    Placeholder="Escribe tu mensaje aquí..."
                                    PlaceholderColor="#AAAAAA"
                                    BackgroundColor="Transparent"
                                    TextColor="#333333"
                                    FontFamily="Nunito"
                                    Margin="12,8"/>
                        </Border>
                    </StackLayout>
                </Border>

            </StackLayout>
        </ScrollView>

        <!-- BOTÓN ENVIAR -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,20">
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>

            <Border BackgroundColor="{StaticResource RojoMarca}"
                    StrokeThickness="0"
                    Padding="0"
                    HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding cmdEmail}"/>
                </Border.GestureRecognizers>
                <StackLayout Orientation="Horizontal"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="10">
                    <Label Text="&#x2709;"
                           FontSize="18"
                           TextColor="White"
                           VerticalOptions="Center"/>
                    <Label Text="Enviar Correo"
                           FontFamily="Nunito_bold"
                           FontSize="16"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </StackLayout>
            </Border>
        </Border>

    </Grid>
</ContentPage>
