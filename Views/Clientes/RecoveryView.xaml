<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.RecoveryView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="RecoveryPage"
    Title="Recuperar contraseña"
    BackgroundColor="#F5F5F5"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource RojoMarca}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontFamily" Value="Nunito"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="25"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="TextColor" Value="#666666"/>
                <Setter Property="FontFamily" Value="Nunito"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="CornerRadius" Value="25"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="Auto, *, Auto"
              Padding="0"
              VerticalOptions="FillAndExpand">

            <VerticalStackLayout Grid.Row="0"
                                 Grid.RowSpan="2"
                                 Spacing="0"
                                 VerticalOptions="Start"
                                 Padding="30,10,30,30">

                <!-- Logo y titulo -->
                <VerticalStackLayout Spacing="8"
                                     HorizontalOptions="Center"
                                     Margin="0,0,0,30">

                    <Image Source="logo_morado.png"
                           HeightRequest="100"
                           HorizontalOptions="Center"
                           Margin="0,0,20,10"
                           Aspect="AspectFit"/>

                    <Label Text="Recuperar contraseña"
                           FontFamily="Nunito"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="Black"
                           HorizontalOptions="Center"/>

                    <Label Text="Introduce tu email y nueva contraseña"
                           FontFamily="Nunito"
                           FontSize="14"
                           TextColor="#666666"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Card del formulario -->
                <Border StrokeThickness="0"
                        Padding="25"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000"
                                Offset="0,4"
                                Radius="20"
                                Opacity="0.1"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!-- Campo Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Correo electronico"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#666666"/>
                            <Border StrokeThickness="1"
                                    Padding="12,8"
                                    BackgroundColor="#FAFAFA">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0"
                                           Text="&#x2709;"
                                           FontSize="18"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1"
                                           Placeholder="tu@email.com"
                                           Keyboard="Email"
                                           Text="{Binding Email}"
                                           BackgroundColor="Transparent"
                                           TextColor="{DynamicResource Negro}"
                                           PlaceholderColor="#BBBBBB"
                                           FontFamily="Nunito"
                                           FontSize="15"/>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Campo Nueva Contraseña -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Nueva contraseña"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#666666"/>
                            <Border StrokeThickness="1"
                                    Padding="12,8"
                                    BackgroundColor="#FAFAFA">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="0"
                                           Text="&#x1F512;"
                                           FontSize="18"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1"
                                           x:Name="PasswordEntry"
                                           Placeholder="********"
                                           IsPassword="True"
                                           Text="{Binding Pass}"
                                           BackgroundColor="Transparent"
                                           TextColor="{DynamicResource Negro}"
                                           PlaceholderColor="#BBBBBB"
                                           FontFamily="Nunito"
                                           FontSize="15"/>
                                    <Label Grid.Column="2"
                                           x:Name="TogglePasswordIcon"
                                           Text="&#x1F441;"
                                           FontSize="18"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="10,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTogglePasswordClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Campo Repetir Contraseña -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Repetir contraseña"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#666666"/>
                            <Border StrokeThickness="1"
                                    Padding="12,8"
                                    BackgroundColor="#FAFAFA">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Label Grid.Column="0"
                                           Text="&#x1F512;"
                                           FontSize="18"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="0,0,10,0"/>
                                    <Entry Grid.Column="1"
                                           x:Name="RePasswordEntry"
                                           Placeholder="********"
                                           IsPassword="True"
                                           Text="{Binding RePass}"
                                           BackgroundColor="Transparent"
                                           TextColor="{DynamicResource Negro}"
                                           PlaceholderColor="#BBBBBB"
                                           FontFamily="Nunito"
                                           FontSize="15"/>
                                    <Label Grid.Column="2"
                                           x:Name="ToggleRePasswordIcon"
                                           Text="&#x1F441;"
                                           FontSize="18"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="10,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnToggleRePasswordClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Boton Solicitar -->
                        <Button Text="Cambiar contraseña"
                                Command="{Binding CommandGuardar}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,15,0,0">
                            <Button.Shadow>
                                <Shadow Brush="{StaticResource RojoMarca}"
                                        Offset="0,4"
                                        Radius="12"
                                        Opacity="0.3"/>
                            </Button.Shadow>
                        </Button>

                        <!-- Boton Cancelar -->
                        <Button Text="Cancelar"
                                Command="{Binding CommandCancelar}"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,0,0"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
