<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.DetalleArticuloNavidadView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:badge="clr-namespace:Syncfusion.Maui.Core;assembly=Syncfusion.Maui.Core"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:templates="clr-namespace:AsadorMoron.Views.Templates"
    x:Name="ViewDetalleArticulosNavidad"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Logo centrado -->
                <Image Grid.Column="1"
                       Source="logo_morado.png"
                       HeightRequest="32"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Carrito con Badge (Solo visible cuando NO es modo tienda) -->
                <Grid Grid.Column="2"
                      WidthRequest="48"
                      HeightRequest="48"
                      IsVisible="{Binding ModoTienda, Converter={StaticResource InverseBoolConverter}}">
                    <Border BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            Padding="8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Image Source="carrito.png" WidthRequest="24" HeightRequest="24" VerticalOptions="Center" HorizontalOptions="Center"/>
                    </Border>
                    <Border BackgroundColor="{DynamicResource Amarillo}"
                            StrokeThickness="0"
                            WidthRequest="22"
                            HeightRequest="22"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,-4,-4,0"
                            IsVisible="{Binding Cantidad, Converter={StaticResource StringEmptyToBooleanConverter}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="11"/>
                        </Border.StrokeShape>
                        <Label Text="{Binding Cantidad}"
                               FontSize="11"
                               FontFamily="Nunito_bold"
                               TextColor="{DynamicResource Negro}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrDetallePedidoCommand}"/>
                    </Grid.GestureRecognizers>
                </Grid>
            </Grid>
        </Border>

        <!-- CONTENIDO SCROLLEABLE -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- CARD: Imagen y detalles del producto -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,*">
                        <!-- Información del producto arriba -->
                        <StackLayout Grid.Row="0" Padding="20,20,20,16" Spacing="8">
                            <!-- Nombre -->
                            <Label FontFamily="Nunito_bold"
                                   FontSize="22"
                                   HorizontalTextAlignment="Center"
                                   Text="{Binding Articulo.nombre}"
                                   TextColor="#333333">
                                <Label.Triggers>
                                    <DataTrigger Binding="{Binding Path=BindingContext.Idioma, Source={x:Reference Name=ViewDetalleArticulosNavidad}}"
                                                 TargetType="Label"
                                                 Value="EN">
                                        <Setter Property="Text" Value="{Binding Articulo.nombre_eng}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=BindingContext.Idioma, Source={x:Reference Name=ViewDetalleArticulosNavidad}}"
                                                 TargetType="Label"
                                                 Value="DE">
                                        <Setter Property="Text" Value="{Binding Articulo.nombre_ger}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=BindingContext.Idioma, Source={x:Reference Name=ViewDetalleArticulosNavidad}}"
                                                 TargetType="Label"
                                                 Value="FR">
                                        <Setter Property="Text" Value="{Binding Articulo.nombre_fr}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <!-- Descripción -->
                            <Label FontFamily="Nunito"
                                   FontSize="14"
                                   HorizontalTextAlignment="Center"
                                   Text="{Binding Articulo.descripcion}"
                                   TextColor="#666666"
                                   LineBreakMode="WordWrap">
                                <Label.Triggers>
                                    <DataTrigger Binding="{Binding Path=BindingContext.Idioma, Source={x:Reference Name=ViewDetalleArticulosNavidad}}"
                                                 TargetType="Label"
                                                 Value="EN">
                                        <Setter Property="Text" Value="{Binding Articulo.descripcion_eng}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=BindingContext.Idioma, Source={x:Reference Name=ViewDetalleArticulosNavidad}}"
                                                 TargetType="Label"
                                                 Value="DE">
                                        <Setter Property="Text" Value="{Binding Articulo.descripcion_ger}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Path=BindingContext.Idioma, Source={x:Reference Name=ViewDetalleArticulosNavidad}}"
                                                 TargetType="Label"
                                                 Value="FR">
                                        <Setter Property="Text" Value="{Binding Articulo.descripcion_fr}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </StackLayout>

                        <!-- Imagen grande del producto -->
                        <Border Grid.Row="1"
                                StrokeThickness="0"
                                Margin="16,0,16,16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <ffimageloading:CachedImage Aspect="AspectFit"
                                                         HeightRequest="280"
                                                         HorizontalOptions="FillAndExpand"
                                                         Source="{Binding Articulo.imagen}"
                                                         VerticalOptions="FillAndExpand"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Espacio inferior para scroll -->
                

            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
