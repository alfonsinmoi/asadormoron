<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.PopupValoracionAppView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:AsadorMoron.ViewModels.Clientes"
    x:DataType="viewmodels:PopupValoracionAppViewModel"
    BackgroundColor="#80000000">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
            <Color x:Key="Amarillo">#FFD700</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Border Margin="24"
            BackgroundColor="White"
            StrokeThickness="0"
            MaximumWidthRequest="400"
            HorizontalOptions="Center"
            VerticalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.3"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto" Padding="0">

            <!-- HEADER -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource RojoMarca}"
                    StrokeThickness="0"
                    Padding="20,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0"/>
                </Border.StrokeShape>

                <StackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="&#x2B50;"
                           FontSize="32"
                           HorizontalOptions="Center"/>
                    <Label Text="Valora tu experiencia"
                           FontFamily="Nunito_bold"
                           FontSize="20"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Tu opinión es importante para nosotros"
                           FontFamily="Nunito"
                           FontSize="13"
                           TextColor="#FFFFFFCC"
                           HorizontalTextAlignment="Center"/>
                </StackLayout>
            </Border>

            <!-- CONTENIDO -->
            <ScrollView Grid.Row="1" Padding="20,16">
                <StackLayout Spacing="20">

                    <!-- Rating con Slider -->
                    <StackLayout Spacing="12">
                        <Label Text="¿Cómo calificarías la app?"
                               FontFamily="Nunito_bold"
                               FontSize="14"
                               TextColor="#333333"
                               HorizontalTextAlignment="Center"/>

                        <!-- Estrellas visuales -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="&#x2B50;" FontSize="28"/>
                            <Label Text="&#x2B50;" FontSize="28"/>
                            <Label Text="&#x2B50;" FontSize="28"/>
                            <Label Text="&#x2B50;" FontSize="28"/>
                            <Label Text="&#x2B50;" FontSize="28"/>
                        </HorizontalStackLayout>

                        <!-- Slider -->
                        <Border BackgroundColor="#F5F5F5"
                                StrokeThickness="0"
                                Padding="16,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Slider Minimum="0"
                                        Maximum="5"
                                        Value="{Binding Valoracion}"
                                        MinimumTrackColor="{StaticResource Amarillo}"
                                        MaximumTrackColor="#E0E0E0"
                                        ThumbColor="{StaticResource RojoMarca}"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="{StaticResource RojoMarca}"
                                        StrokeThickness="0"
                                        WidthRequest="44"
                                        HeightRequest="32">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Valoracion, StringFormat='{0:F1}'}"
                                           FontFamily="Nunito_bold"
                                           FontSize="14"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackLayout>

                    <!-- Comentario -->
                    <StackLayout Spacing="8">
                        <Label Text="Déjanos un comentario"
                               FontFamily="Nunito_bold"
                               FontSize="14"
                               TextColor="#333333"/>
                        <Label Text="Nos ayudará a mejorar nuestro servicio"
                               FontFamily="Nunito"
                               FontSize="12"
                               TextColor="#888888"/>
                        <Border BackgroundColor="#FAFAFA"
                                StrokeThickness="1"
                                Stroke="#E8E8E8"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding Comentario}"
                                    Placeholder="Escribe tu comentario aquí..."
                                    PlaceholderColor="#AAAAAA"
                                    HeightRequest="100"
                                    BackgroundColor="Transparent"
                                    TextColor="#333333"
                                    FontFamily="Nunito"
                                    FontSize="14"
                                    Margin="12,8"/>
                        </Border>
                    </StackLayout>

                </StackLayout>
            </ScrollView>

            <!-- BOTONES -->
            <Border Grid.Row="2"
                    BackgroundColor="#F5F5F5"
                    StrokeThickness="0"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,24,24"/>
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Cancelar -->
                    <Border BackgroundColor="White"
                            StrokeThickness="1"
                            Stroke="#E0E0E0"
                            Padding="0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClosePopUpCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontFamily="Nunito_bold"
                               FontSize="15"
                               TextColor="#666666"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Enviar -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AceptarCommand}"/>
                        </Border.GestureRecognizers>
                        <StackLayout Orientation="Horizontal"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="8">
                            <Label Text="&#x2714;"
                                   FontSize="16"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <Label Text="Enviar"
                                   FontFamily="Nunito_bold"
                                   FontSize="15"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                        </StackLayout>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Border>
</ContentPage>
