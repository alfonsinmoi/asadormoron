<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.DetallePedidoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="DetallePedido"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Tu Pedido"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="#333333"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <!-- Espacio para balance -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>
            </Grid>
        </Border>

        <!-- CONTENIDO SCROLLEABLE -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="12">

                <!-- ALERTA: Saldo acumulado -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        Padding="16,12"
                        IsVisible="{Binding VisibleSaldo}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding Saldo, StringFormat='Tiene un saldo acumulado de {0:C2}'}"
                           FontFamily="Nunito_bold"
                           FontSize="14"
                           TextColor="White"/>
                </Border>

                <!-- ALERTA: Promoción pendiente -->
                <Border BackgroundColor="#FF9800"
                        StrokeThickness="0"
                        Padding="16,12"
                        IsVisible="{Binding PendientePromocion}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding TextoPromocion}"
                           FontFamily="Nunito_bold"
                           FontSize="14"
                           TextColor="White"/>
                </Border>

                <!-- CARD: Productos del carrito -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <!-- Header -->
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Border BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" Padding="10,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="PRODUCTOS" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </Border>
                        </StackLayout>

                        <!-- Lista de productos -->
                        <StackLayout BindableLayout.ItemsSource="{Binding Carrito}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <!-- Controles de cantidad -->
                                            <Border Grid.Column="0" BackgroundColor="#EEEEEE" StrokeThickness="0" Padding="4" VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="32,28,32" ColumnSpacing="2">
                                                    <Border Grid.Column="0" BackgroundColor="White" StrokeThickness="0" HeightRequest="32" WidthRequest="32">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8"/>
                                                        </Border.StrokeShape>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Path=BindingContext.ClickMenosCommand, Source={x:Reference Name=DetallePedido}}" CommandParameter="{Binding idArticulo}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="−" FontSize="16" TextColor="{StaticResource RojoMarca}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Label Grid.Column="1"
                                                           FontFamily="Nunito_bold"
                                                           FontSize="14"
                                                           HorizontalTextAlignment="Center"
                                                           Text="{Binding cantidad, Mode=TwoWay}"
                                                           TextColor="#333333"
                                                           VerticalTextAlignment="Center"/>
                                                    <Border Grid.Column="2" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" HeightRequest="32" WidthRequest="32">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8"/>
                                                        </Border.StrokeShape>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Path=BindingContext.ClickMasCommand, Source={x:Reference Name=DetallePedido}}" CommandParameter="{Binding idArticulo}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="+" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                        <Border.Triggers>
                                                            <DataTrigger Binding="{Binding porPuntos}" TargetType="Border" Value="1">
                                                                <Setter Property="IsVisible" Value="False"/>
                                                            </DataTrigger>
                                                        </Border.Triggers>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Info del producto -->
                                            <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label FontFamily="Nunito_bold" FontSize="14" Text="{Binding comida}" TextColor="#333333"/>
                                                <Label FontFamily="Nunito" FontSize="12" Text="{Binding comentario}" TextColor="#888888" IsVisible="{Binding comentario, Converter={StaticResource StringEmptyToBooleanConverter}}"/>
                                                <Label FontFamily="Nunito" FontSize="12" Text="{Binding precio, StringFormat='Precio: {0:N2}€'}" TextColor="#666666"/>
                                            </StackLayout>

                                            <!-- Precio total -->
                                            <Label Grid.Column="2"
                                                   FontFamily="Nunito_bold"
                                                   FontSize="15"
                                                   Text="{Binding precioTotal, StringFormat='{0:N2}€'}"
                                                   TextColor="{StaticResource RojoMarca}"
                                                   VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger Binding="{Binding porPuntos}" TargetType="Label" Value="1">
                                                        <Setter Property="Text" Value="{Binding puntos, StringFormat='{0} pts'}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- CARD: Resumen de precios -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="8">
                        <!-- Gastos de envío -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Gastos de envío" FontFamily="Nunito" FontSize="14" TextColor="#666666"/>
                            <Label Grid.Column="1" Text="{Binding Gastos, StringFormat='{0:N2}€'}" FontFamily="Nunito" FontSize="14" TextColor="#333333"/>
                        </Grid>
                        <!-- Subtotal -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Subtotal" FontFamily="Nunito" FontSize="14" TextColor="#666666"/>
                            <Label Grid.Column="1" Text="{Binding PrecioTotalPedido, StringFormat='{0:N2}€'}" FontFamily="Nunito" FontSize="14" TextColor="#333333"/>
                        </Grid>
                        <!-- Bolsa -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Bolsa" FontFamily="Nunito" FontSize="14" TextColor="#666666"/>
                            <Label Grid.Column="1" Text="{Binding Bolsa, StringFormat='{0:N2}€'}" FontFamily="Nunito" FontSize="14" TextColor="#333333"/>
                        </Grid>
                        <!-- Separador -->
                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,8"/>
                        <!-- TOTAL -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="TOTAL" FontFamily="Nunito_bold" FontSize="18" TextColor="#333333"/>
                            <Label Grid.Column="1" Text="{Binding PrecioTotalPedidoGastos, StringFormat='{0:N2}€'}" FontFamily="Nunito_bold" FontSize="20" TextColor="{StaticResource RojoMarca}"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- Botón usar saldo -->
                <Button Text="Utilizar Saldo acumulado"
                        BackgroundColor="{StaticResource RojoMarca}"
                        TextColor="White"
                        FontFamily="Nunito_bold"
                        FontSize="14"
                        CornerRadius="12"
                        HeightRequest="48"
                        IsVisible="{Binding VisibleSaldo}"
                        Command="{Binding RestarSaldoCommand}"/>

                <!-- CARD: Tipo de pedido -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="¿Cómo desea el pedido?" FontFamily="Nunito_bold" FontSize="14" TextColor="#333333"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <!-- Envío a domicilio -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#FAFAFA"
                                    StrokeThickness="0"
                                    Padding="12"
                                    IsVisible="{Binding TieneEnvio}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <StackLayout Spacing="4" HorizontalOptions="Center">
                                    <CheckBox IsChecked="{Binding Envio}" Color="{StaticResource RojoMarca}" HorizontalOptions="Center"/>
                                    <Label Text="Envío a domicilio" FontFamily="Nunito" FontSize="12" TextColor="#333333" HorizontalTextAlignment="Center"/>
                                </StackLayout>
                            </Border>
                            <!-- Recoger en local -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#FAFAFA"
                                    StrokeThickness="0"
                                    Padding="12"
                                    IsVisible="{Binding TieneRecogida}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <StackLayout Spacing="4" HorizontalOptions="Center">
                                    <CheckBox IsChecked="{Binding Recogida}" Color="{StaticResource RojoMarca}" HorizontalOptions="Center"/>
                                    <Label Text="Recoger en local" FontFamily="Nunito" FontSize="12" TextColor="#333333" HorizontalTextAlignment="Center"/>
                                </StackLayout>
                            </Border>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- CARD: Dirección de envío -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        IsVisible="{Binding Envio}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Border BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" Padding="10,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="DIRECCIÓN DE ENVÍO" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </Border>
                        </StackLayout>
                        <!-- Dirección -->
                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Dirección"
                                   Text="{Binding Direccion}"
                                   IsEnabled="{Binding CambiaDireccion}"
                                   TextColor="#333333"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   BackgroundColor="Transparent"
                                   Margin="12,0"/>
                        </Border>
                        <!-- Zona -->
                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Picker Title="Selecciona zona"
                                    ItemsSource="{Binding Zonas}"
                                    ItemDisplayBinding="{Binding nombre}"
                                    SelectedItem="{Binding ZonaSeleccionda}"
                                    IsEnabled="{Binding Modificable}"
                                    TextColor="#333333"
                                    FontFamily="Nunito"/>
                        </Border>
                        <!-- Población cambiada -->
                        <Label Text="{Binding Poblacion}"
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#666666"
                               IsVisible="{Binding PuebloCambiado}"/>
                    </StackLayout>
                </Border>

                <!-- CARD: Forma de pago -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Border BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" Padding="10,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="FORMA DE PAGO" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </Border>
                        </StackLayout>

                        <!-- Efectivo -->
                        <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12" IsVisible="{Binding TieneEfectivo}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*">
                                <CheckBox IsChecked="{Binding Efectivo}" Color="{StaticResource RojoMarca}"/>
                                <Label Grid.Column="1" Text="Efectivo o Datáfono en casa" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Tarjeta -->
                        <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12" IsVisible="{Binding TieneTarjeta}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <StackLayout Spacing="10">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <CheckBox IsChecked="{Binding Tarjeta}" Color="{StaticResource RojoMarca}"/>
                                    <Label Grid.Column="1" Text="Tarjeta" FontFamily="Nunito" FontSize="14" TextColor="#333333" VerticalOptions="Center"/>
                                    <Button Grid.Column="2"
                                            Text="+ Nueva"
                                            BackgroundColor="{StaticResource RojoMarca}"
                                            TextColor="White"
                                            FontFamily="Nunito_bold"
                                            FontSize="11"
                                            CornerRadius="8"
                                            Padding="10,0"
                                            HeightRequest="32"
                                            Command="{Binding NavigateToAddCreditCardPageCommand}"/>
                                </Grid>

                                <!-- Lista de tarjetas -->
                                <StackLayout IsVisible="{Binding Tarjeta}" BindableLayout.ItemsSource="{Binding Cards}" Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E0E0E0" Padding="10">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                                                    <CheckBox IsEnabled="False" IsChecked="{Binding Seleccionada, Mode=TwoWay}" Color="{StaticResource RojoMarca}"/>
                                                    <Image Grid.Column="1" Source="visa.png" WidthRequest="36" HeightRequest="24" VerticalOptions="Center">
                                                        <Image.Triggers>
                                                            <DataTrigger Binding="{Binding tarjeta.cardBrand}" TargetType="Image" Value="VISA">
                                                                <Setter Property="Source" Value="visa.png"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding tarjeta.cardBrand}" TargetType="Image" Value="MASTERCARD">
                                                                <Setter Property="Source" Value="mastercard.png"/>
                                                            </DataTrigger>
                                                        </Image.Triggers>
                                                    </Image>
                                                    <StackLayout Grid.Column="2" Spacing="0" VerticalOptions="Center">
                                                        <Label Text="{Binding tarjeta.pan}" FontFamily="Nunito_bold" FontSize="13" TextColor="#333333"/>
                                                        <Label Text="{Binding tarjeta.expiryDate}" FontFamily="Nunito" FontSize="11" TextColor="#888888"/>
                                                    </StackLayout>
                                                    <Border Grid.Column="3" BackgroundColor="#FFEBEE" StrokeThickness="0" Padding="8" VerticalOptions="Center">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="8"/>
                                                        </Border.StrokeShape>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Path=BindingContext.EliminarTarjetaCommand, Source={x:Reference Name=DetallePedido}}" CommandParameter="{Binding .}"/>
                                                        </Border.GestureRecognizers>
                                                        <Label Text="&#x2715;" FontSize="12" TextColor="{StaticResource RojoMarca}" HorizontalOptions="Center" VerticalOptions="Center"/>
                                                    </Border>
                                                    <Grid.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Path=BindingContext.SeleccionaTarjeta, Source={x:Reference Name=DetallePedido}}" CommandParameter="{Binding .}"/>
                                                    </Grid.GestureRecognizers>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </StackLayout>
                            </StackLayout>
                        </Border>
                    </StackLayout>
                </Border>

                <!-- CARD: Observaciones -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        Margin="0,0,0,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <StackLayout Orientation="Horizontal" Spacing="8">
                            <Border BackgroundColor="#607D8B" StrokeThickness="0" Padding="10,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="OBSERVACIONES" FontFamily="Nunito_bold" FontSize="12" TextColor="White"/>
                            </Border>
                        </StackLayout>
                        <Border StrokeThickness="1" Stroke="#E8E8E8" BackgroundColor="#FAFAFA" Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding Observaciones, Mode=TwoWay}"
                                    HeightRequest="80"
                                    Placeholder="Escribe tus observaciones aquí..."
                                    PlaceholderColor="#AAAAAA"
                                    BackgroundColor="Transparent"
                                    TextColor="#333333"
                                    FontFamily="Nunito"
                                    Margin="12,8"/>
                        </Border>
                    </StackLayout>
                </Border>
            </StackLayout>
        </ScrollView>

        <!-- BOTÓN ENVIAR PEDIDO -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,20">
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>
            <Button BackgroundColor="{StaticResource RojoMarca}"
                    Command="{Binding EnviarPedidoCommand}"
                    CornerRadius="16"
                    FontFamily="Nunito_bold"
                    FontSize="16"
                    HeightRequest="52"
                    HorizontalOptions="FillAndExpand"
                    Text="Seleccione una hora"
                    TextColor="White"/>
        </Border>
    </Grid>
</ContentPage>
