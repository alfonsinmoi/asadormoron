<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.PagoErroneoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="PagoErrorView"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <StackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="2">
                    <Label Text="Error de Pago"
                           FontFamily="Nunito_bold"
                           FontSize="18"
                           TextColor="#333333"
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Espacio -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16" VerticalOptions="Center">

                <!-- CARD: Error -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="24">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                    </Border.Shadow>

                    <StackLayout Spacing="20" HorizontalOptions="Center">
                        <!-- Icono de Error -->
                        <Border BackgroundColor="#FFEBEE"
                                StrokeThickness="0"
                                WidthRequest="100"
                                HeightRequest="100"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50"/>
                            </Border.StrokeShape>
                            <Label Text="&#x2715;"
                                   FontSize="48"
                                   TextColor="{StaticResource RojoMarca}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <!-- Logo -->
                        <Image Source="logo_morado.png"
                               HeightRequest="60"
                               Aspect="AspectFit"
                               BackgroundColor="White"
                               HorizontalOptions="Center"/>

                        <!-- Mensaje Principal -->
                        <Label Text="Se ha producido un error en el pago"
                               FontFamily="Nunito_bold"
                               FontSize="20"
                               TextColor="#333333"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>

                        <!-- Separador -->
                        <BoxView HeightRequest="1"
                                 BackgroundColor="#E0E0E0"
                                 HorizontalOptions="FillAndExpand"
                                 Margin="20,0"/>

                        <!-- Detalle del Error -->
                        <Border BackgroundColor="#FFF8E1"
                                StrokeThickness="0"
                                Padding="16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <StackLayout Orientation="Horizontal" Spacing="12">
                                <Label Text="&#x26A0;"
                                       FontSize="24"
                                       TextColor="#FF9800"
                                       VerticalOptions="Start"/>
                                <Label Text="{Binding Texto}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="#333333"
                                       LineBreakMode="WordWrap"
                                       VerticalOptions="Center"
                                       HorizontalOptions="FillAndExpand"/>
                            </StackLayout>
                        </Border>

                        <!-- Mensaje de ayuda -->
                        <Label Text="Por favor, inténtelo de nuevo o contacte con nosotros si el problema persiste."
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"/>
                    </StackLayout>
                </Border>

            </StackLayout>
        </ScrollView>

        <!-- BOTÓN ACEPTAR -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,20">
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,-2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>

            <Border BackgroundColor="{StaticResource RojoMarca}"
                    StrokeThickness="0"
                    Padding="0"
                    HeightRequest="52">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding VolverCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="Aceptar"
                       FontFamily="Nunito_bold"
                       FontSize="16"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
        </Border>

    </Grid>
</ContentPage>
