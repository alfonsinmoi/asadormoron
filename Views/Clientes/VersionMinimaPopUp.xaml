<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.VersionMinimaPopUp"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasBackButton="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Padding="24" VerticalOptions="Center">

        <!-- CARD Principal -->
        <Border BackgroundColor="White"
                StrokeThickness="0"
                Padding="0"
                MaximumWidthRequest="400">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,8" Radius="24" Opacity="0.2"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- HEADER -->
                <Border Grid.Row="0"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        Padding="24,20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24,24,0,0"/>
                    </Border.StrokeShape>

                    <StackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="#FFFFFF30"
                                StrokeThickness="0"
                                WidthRequest="70"
                                HeightRequest="70"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="35"/>
                            </Border.StrokeShape>
                            <Label Text="&#x1F4F2;"
                                   FontSize="36"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Actualización Requerida"
                               FontFamily="Nunito_bold"
                               FontSize="20"
                               TextColor="White"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>

                <!-- CONTENIDO -->
                <StackLayout Grid.Row="1" Padding="24,20" Spacing="20">

                    <!-- Logo -->
                    <Image Source="logo_morado.png"
                           HeightRequest="60"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"/>

                    <!-- Mensaje -->
                    <Border BackgroundColor="#FFF8E1"
                            StrokeThickness="0"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <StackLayout Spacing="8">
                            <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="Center">
                                <Label Text="&#x26A0;"
                                       FontSize="20"
                                       TextColor="#FF9800"
                                       VerticalOptions="Center"/>
                                <Label Text="Nueva versión disponible"
                                       FontFamily="Nunito_bold"
                                       FontSize="15"
                                       TextColor="#333333"
                                       VerticalOptions="Center"/>
                            </StackLayout>
                            <Label Text="{Binding Texto}"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="#333333"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>
                    </Border>

                    <!-- Indicador de carga -->
                    <StackLayout HorizontalOptions="Center" Spacing="8">
                        <ActivityIndicator IsRunning="True"
                                           Color="{StaticResource RojoMarca}"
                                           HeightRequest="40"
                                           WidthRequest="40"/>
                        <Label Text="Verificando..."
                               FontFamily="Nunito"
                               FontSize="12"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>

                    <!-- Información adicional -->
                    <StackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="Para continuar usando la app,"
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="actualiza a la última versión."
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>

                </StackLayout>

                <!-- BOTÓN -->
                <Border Grid.Row="2"
                        BackgroundColor="#F5F5F5"
                        StrokeThickness="0"
                        Padding="20,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,24,24"/>
                    </Border.StrokeShape>

                    <Border BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="52">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding cmdActualizar}"/>
                        </Border.GestureRecognizers>
                        <StackLayout Orientation="Horizontal"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10">
                            <Label Text="&#x2B06;"
                                   FontSize="18"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <Label Text="Actualizar Ahora"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                        </StackLayout>
                    </Border>
                </Border>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
