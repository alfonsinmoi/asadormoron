<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.AddCreditCardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:AsadorMoron.ViewModels.Clientes"
    xmlns:controls="clr-namespace:AsadorMoron.Controls"
    x:DataType="viewmodels:AddCreditCardPageViewModel"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5"
    mc:Ignorable="d">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Añadir Tarjeta"
                       FontFamily="Nunito_bold"
                       FontSize="18"
                       TextColor="#333333"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <!-- Espacio -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>
            </Grid>
        </Border>

        <!-- CONTENIDO: WebView -->
        <Border Grid.Row="1"
                Margin="16"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
            </Border.Shadow>
            <controls:CustomWebView x:Name="webView"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"/>
        </Border>
    </Grid>
</ContentPage>
