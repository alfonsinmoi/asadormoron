<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.RegistroView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    x:Name="RegistroPage"
    Title="Registro"
    BackgroundColor="#F5F5F5"
    NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource RojoMarca}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontFamily" Value="Nunito"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="25"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{DynamicResource Amarillo}"/>
                <Setter Property="TextColor" Value="{DynamicResource Negro}"/>
                <Setter Property="FontFamily" Value="Nunito"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="25"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="TextColor" Value="#666666"/>
                <Setter Property="FontFamily" Value="Nunito"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="CornerRadius" Value="25"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontFamily" Value="Nunito"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="TextColor" Value="#666666"/>
            </Style>

            <Style x:Key="FieldBorder" TargetType="Border">
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BackgroundColor" Value="#FAFAFA"/>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0"
                             Padding="30,10,30,30">

            <!-- Logo y titulo -->
            <VerticalStackLayout Spacing="8"
                                 HorizontalOptions="Center"
                                 Margin="0,0,0,20">

                <Image Source="logo_morado.png"
                       HeightRequest="80"
                       BackgroundColor="Transparent"
                       HorizontalOptions="Center"
                       Margin="0,0,20,10"
                       Aspect="AspectFit"/>

                <Label Text="Crear cuenta"
                       FontFamily="Nunito"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="Black"
                       HorizontalOptions="Center"/>

                <Label Text="Completa tus datos para registrarte"
                       FontFamily="Nunito"
                       FontSize="14"
                       TextColor="#666666"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Imagen de perfil -->
            <VerticalStackLayout HorizontalOptions="Center" Margin="0,0,0,20">
                <Border StrokeThickness="3"
                        Stroke="{StaticResource RojoMarca}"
                        HeightRequest="100"
                        WidthRequest="100"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="50"/>
                    </Border.StrokeShape>
                    <ff:CachedImage Source="{Binding Imagen}"
                                    Aspect="AspectFill"
                                    HeightRequest="100"
                                    WidthRequest="100">
                        <ff:CachedImage.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CmdCambiaImagen}"/>
                        </ff:CachedImage.GestureRecognizers>
                    </ff:CachedImage>
                </Border>
                <Label Text="Toca para cambiar foto"
                       FontFamily="Nunito"
                       FontSize="12"
                       TextColor="#999999"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0"/>
            </VerticalStackLayout>

            <!-- Card del formulario -->
            <Border StrokeThickness="0"
                    Padding="20"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000"
                            Offset="0,4"
                            Radius="20"
                            Opacity="0.1"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">

                    <!-- Nombre -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Nombre" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Tu nombre"
                                   Text="{Binding Nombre}"
                                   BackgroundColor="Transparent"
                                   TextColor="{DynamicResource Negro}"
                                   PlaceholderColor="#BBBBBB"
                                   FontFamily="Nunito"
                                   FontSize="15"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Apellidos -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Apellidos" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Tus apellidos"
                                   Text="{Binding Apellidos}"
                                   BackgroundColor="Transparent"
                                   TextColor="{DynamicResource Negro}"
                                   PlaceholderColor="#BBBBBB"
                                   FontFamily="Nunito"
                                   FontSize="15"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Telefono -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Telefono" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Tu telefono"
                                   Keyboard="Telephone"
                                   Text="{Binding Telefono}"
                                   BackgroundColor="Transparent"
                                   TextColor="{DynamicResource Negro}"
                                   PlaceholderColor="#BBBBBB"
                                   FontFamily="Nunito"
                                   FontSize="15"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Correo electronico" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Label Grid.Column="0"
                                       Text="&#x2709;"
                                       FontSize="18"
                                       TextColor="#999999"
                                       VerticalOptions="Center"
                                       Margin="0,0,10,0"/>
                                <Entry Grid.Column="1"
                                       Placeholder="tu@email.com"
                                       Keyboard="Email"
                                       Text="{Binding Email}"
                                       BackgroundColor="Transparent"
                                       TextColor="{DynamicResource Negro}"
                                       PlaceholderColor="#BBBBBB"
                                       FontFamily="Nunito"
                                       FontSize="15"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Provincia -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Provincia" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Picker Title="Selecciona Provincia"
                                    ItemsSource="{Binding Provincias}"
                                    SelectedItem="{Binding Provincia}"
                                    FontFamily="Nunito"
                                    FontSize="15"
                                    TextColor="{DynamicResource Negro}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Poblacion y Cod. Postal -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Poblacion" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Picker Title="Poblacion"
                                        ItemsSource="{Binding Pueblos}"
                                        SelectedItem="{Binding Poblacion}"
                                        FontFamily="Nunito"
                                        FontSize="14"
                                        TextColor="{DynamicResource Negro}"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Cod. Postal" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Picker Title="C.P."
                                        ItemsSource="{Binding CodPostales}"
                                        ItemDisplayBinding="{Binding codPostal}"
                                        SelectedItem="{Binding CodPostal}"
                                        FontFamily="Nunito"
                                        FontSize="14"
                                        TextColor="{DynamicResource Negro}"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Zona -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Zona" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Picker Title="Selecciona Zona"
                                    ItemsSource="{Binding Zonas}"
                                    ItemDisplayBinding="{Binding nombre}"
                                    SelectedItem="{Binding Zona}"
                                    FontFamily="Nunito"
                                    FontSize="15"
                                    TextColor="{DynamicResource Negro}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Direccion -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Direccion" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Tu direccion"
                                   Text="{Binding Direccion}"
                                   BackgroundColor="Transparent"
                                   TextColor="{DynamicResource Negro}"
                                   PlaceholderColor="#BBBBBB"
                                   FontFamily="Nunito"
                                   FontSize="15"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Separador -->
                    <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10"/>

                    <Label Text="Datos de acceso"
                           FontFamily="Nunito"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource RojoMarca}"/>

                    <!-- Contraseñas -->
                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Contrasena" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Entry Grid.Column="0"
                                           x:Name="PasswordEntry"
                                           Placeholder="********"
                                           IsPassword="True"
                                           Text="{Binding Pass}"
                                           BackgroundColor="Transparent"
                                           TextColor="{DynamicResource Negro}"
                                           PlaceholderColor="#BBBBBB"
                                           FontFamily="Nunito"
                                           FontSize="14"/>
                                    <Label Grid.Column="1"
                                           x:Name="TogglePasswordIcon"
                                           Text="&#x1F441;"
                                           FontSize="16"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="5,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTogglePasswordClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Repetir" Style="{StaticResource FieldLabel}"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*, Auto">
                                    <Entry Grid.Column="0"
                                           x:Name="RePasswordEntry"
                                           Placeholder="********"
                                           IsPassword="True"
                                           Text="{Binding RePass}"
                                           BackgroundColor="Transparent"
                                           TextColor="{DynamicResource Negro}"
                                           PlaceholderColor="#BBBBBB"
                                           FontFamily="Nunito"
                                           FontSize="14"/>
                                    <Label Grid.Column="1"
                                           x:Name="ToggleRePasswordIcon"
                                           Text="&#x1F441;"
                                           FontSize="16"
                                           TextColor="#999999"
                                           VerticalOptions="Center"
                                           Margin="5,0,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnToggleRePasswordClicked"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Codigo amigo -->
                    <VerticalStackLayout Spacing="6" IsVisible="{Binding TieneCodigoAmigo}">
                        <Label Text="Codigo de amigo (opcional)" Style="{StaticResource FieldLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Introduce el codigo"
                                   Text="{Binding Codigo}"
                                   BackgroundColor="Transparent"
                                   TextColor="{DynamicResource Negro}"
                                   PlaceholderColor="#BBBBBB"
                                   FontFamily="Nunito"
                                   FontSize="15"/>
                        </Border>
                        <Label Text="{Binding TextoPromo}"
                               FontFamily="Nunito"
                               FontSize="12"
                               TextColor="#999999"/>
                    </VerticalStackLayout>

                    <!-- Botones -->
                    <Button Text="Registrarme"
                            Command="{Binding CommandGuardar}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,20,0,0">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource RojoMarca}"
                                    Offset="0,4"
                                    Radius="12"
                                    Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>

                    <Button Text="Cancelar"
                            Command="{Binding CommandCancelar}"
                            Style="{StaticResource GhostButton}"
                            Margin="0,5,0,0"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
