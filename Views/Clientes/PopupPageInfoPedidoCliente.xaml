<?xml version="1.0" encoding="utf-8" ?>
<popup:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 xmlns:popup="clr-namespace:Mopups.Pages;assembly=Mopups"
                 x:Class="AsadorMoron.Views.Clientes.PopupPageInfoPedidoCliente"
                 BackgroundColor="#80000000">

    <popup:PopupPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </popup:PopupPage.Resources>

    <Border x:Name="MainCard"
            BackgroundColor="White"
            StrokeThickness="0"
            Margin="24"
            Padding="0"
            MaximumHeightRequest="600"
            HorizontalOptions="Fill"
            VerticalOptions="Center">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.3"/>
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- HEADER -->
            <Border Grid.Row="0"
                    BackgroundColor="{StaticResource RojoMarca}"
                    StrokeThickness="0"
                    Padding="20,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0"/>
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <StackLayout VerticalOptions="Center" Spacing="4">
                        <Label Text="Detalle del Pedido"
                               FontFamily="Nunito_bold"
                               FontSize="20"
                               TextColor="White"/>
                        <Label x:Name="LbCodigoPedido"
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#FFFFFFCC"/>
                    </StackLayout>

                    <!-- Botón Cerrar -->
                    <Border Grid.Column="1"
                            BackgroundColor="#FFFFFF30"
                            StrokeThickness="0"
                            WidthRequest="36"
                            HeightRequest="36"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#x2715;"
                               FontSize="16"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- CONTENIDO SCROLLEABLE -->
            <ScrollView Grid.Row="1" Padding="0">
                <StackLayout Spacing="0">

                    <!-- INFORMACIÓN DEL PEDIDO -->
                    <StackLayout x:Name="InfoSection" Padding="20,16" Spacing="12">

                        <!-- Establecimiento -->
                        <Grid x:Name="EstablecimientoStack" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#FFF5F5"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F3EA;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Establecimiento"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="Establecimiento"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"/>
                            </StackLayout>
                        </Grid>

                        <!-- Dirección -->
                        <Grid x:Name="DireccionStack" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#FFF5F5"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4CD;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Dirección"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="Direccion"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"
                                       LineBreakMode="WordWrap"/>
                            </StackLayout>
                        </Grid>

                        <!-- Zona -->
                        <Grid x:Name="ZonaStack" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#FFF5F5"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4CD;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Zona"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="Zona"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"/>
                            </StackLayout>
                        </Grid>

                        <!-- Tipo de Pago -->
                        <Grid x:Name="TipoPagoStack" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#FFF5F5"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4B3;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Método de pago"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="TipoPago"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"/>
                            </StackLayout>
                        </Grid>
                    </StackLayout>

                    <!-- SEPARADOR -->
                    <BoxView HeightRequest="8" Color="#F5F5F5"/>

                    <!-- PRODUCTOS -->
                    <StackLayout Padding="20,16" Spacing="12">
                        <Label Text="Productos"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="#333333"/>

                        <StackLayout x:Name="ProductosList" Spacing="8" BindableLayout.ItemsSource="{Binding}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FAFAFA"
                                            StrokeThickness="0"
                                            Padding="12,10">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <!-- Cantidad -->
                                            <Border BackgroundColor="{StaticResource RojoMarca}"
                                                    StrokeThickness="0"
                                                    WidthRequest="28"
                                                    HeightRequest="28"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding cantidad}"
                                                       FontFamily="Nunito_bold"
                                                       FontSize="13"
                                                       TextColor="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <!-- Nombre -->
                                            <Label Grid.Column="1"
                                                   Text="{Binding nombreProducto}"
                                                   FontFamily="Nunito"
                                                   FontSize="14"
                                                   TextColor="#333333"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2"/>
                                            <!-- Precio -->
                                            <Label Grid.Column="2"
                                                   Text="{Binding importe, StringFormat='{0:N2} €'}"
                                                   FontFamily="Nunito_bold"
                                                   FontSize="14"
                                                   TextColor="{StaticResource RojoMarca}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>
                    </StackLayout>

                    <!-- OBSERVACIONES -->
                    <StackLayout x:Name="ComentarioStack" Padding="20,0,20,16" Spacing="8">
                        <Label Text="Observaciones"
                               FontFamily="Nunito_bold"
                               FontSize="14"
                               TextColor="#333333"/>
                        <Border BackgroundColor="#FFF8E1"
                                StrokeThickness="0"
                                Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <StackLayout Orientation="Horizontal" Spacing="8">
                                <Label Text="&#x1F4DD;"
                                       FontSize="16"
                                       VerticalOptions="Start"/>
                                <Label x:Name="Comentario"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#333333"
                                       LineBreakMode="WordWrap"/>
                            </StackLayout>
                        </Border>
                    </StackLayout>

                </StackLayout>
            </ScrollView>

            <!-- FOOTER: TOTAL -->
            <Border Grid.Row="2"
                    x:Name="TotalStack"
                    BackgroundColor="#F5F5F5"
                    StrokeThickness="0"
                    Padding="20,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="0,0,24,24"/>
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">
                    <StackLayout VerticalOptions="Center">
                        <Label Text="Total del pedido"
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="#888888"/>
                        <Label x:Name="Total"
                               FontFamily="Nunito_bold"
                               FontSize="24"
                               TextColor="{StaticResource RojoMarca}"/>
                    </StackLayout>

                    <!-- Botón Cerrar -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            Padding="24,12"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cerrar"
                               FontFamily="Nunito_bold"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Border>

        </Grid>
    </Border>
</popup:PopupPage>
