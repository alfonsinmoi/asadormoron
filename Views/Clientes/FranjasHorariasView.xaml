<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Clientes.FranjasHorariasView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
            <Style TargetType="Grid">
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- HEADER MODERNO -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12,16,16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,4" Radius="8" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú Hamburguesa (visible cuando es página raíz) -->
                <Border x:Name="BtnMenu" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2630;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Botón Atrás (visible cuando hay páginas en el stack) -->
                <Border x:Name="BtnBack" BackgroundColor="{StaticResource RojoMarca}" StrokeThickness="0" WidthRequest="44" HeightRequest="44" IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;" FontSize="22" TextColor="{DynamicResource Negro}" VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <StackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="2">
                    <Label Text="Seleccionar Hora"
                           FontFamily="Nunito_bold"
                           FontSize="18"
                           TextColor="#333333"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding Texto}"
                           FontFamily="Nunito"
                           FontSize="13"
                           TextColor="#888888"
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Espacio -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>
            </Grid>
        </Border>

        <!-- CONTENIDO: Grid de Horarios -->
        <Border Grid.Row="1"
                Margin="16,16,16,8"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.1"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*">
                <!-- Icono y texto informativo -->
                <StackLayout Grid.Row="0"
                             Orientation="Horizontal"
                             Spacing="12"
                             Margin="0,0,0,16">
                    <Border BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            WidthRequest="44"
                            HeightRequest="44"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Label Text="&#x1F552;"
                               FontSize="20"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <StackLayout VerticalOptions="Center" Spacing="2">
                        <Label Text="Horarios disponibles"
                               FontFamily="Nunito_bold"
                               FontSize="15"
                               TextColor="#333333"/>
                        <Label Text="Selecciona tu franja horaria preferida"
                               FontFamily="Nunito"
                               FontSize="12"
                               TextColor="#888888"/>
                    </StackLayout>
                </StackLayout>

                <!-- CollectionView de Horarios -->
                <CollectionView Grid.Row="1"
                                BackgroundColor="Transparent"
                                ItemsSource="{Binding Listado}"
                                SelectedItem="{Binding FranjaSeleccionada}"
                                SelectionMode="Single">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="{OnIdiom Phone=2, Tablet=4, Desktop=4, Default=2}"
                                         HorizontalItemSpacing="10"
                                         VerticalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{Binding Color}"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="56">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#30000000" Offset="0,2" Radius="4" Opacity="0.15"/>
                                </Border.Shadow>
                                <Label Text="{Binding horaInicio}"
                                       FontFamily="Nunito_bold"
                                       FontSize="18"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger Binding="{Binding Color}"
                                                     TargetType="Label"
                                                     Value="#f0dd49">
                                            <Setter Property="TextColor" Value="#333333"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal"/>
                            <VisualState Name="Selected">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="Transparent"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </CollectionView>
            </Grid>
        </Border>

        <!-- BOTÓN ENVIAR PEDIDO -->
        <Border Grid.Row="2"
                Margin="16,8,16,24"
                BackgroundColor="{StaticResource RojoMarca}"
                StrokeThickness="0"
                Padding="0"
                HeightRequest="56">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.4"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding EnviarPedidoCommand}"/>
            </Border.GestureRecognizers>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" HorizontalOptions="Center">
                <Label Grid.Column="0"
                       Text="&#x2714;"
                       FontSize="18"
                       TextColor="White"
                       VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="Confirmar y Enviar Pedido"
                       FontFamily="Nunito_bold"
                       FontSize="16"
                       TextColor="White"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
