<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Establecimientos.ConfiguracionEstablecimientoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Name="ViewConfiguracion"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Menú -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Image Source="menu.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Ajustes"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Guardar -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Image Source="save.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GuardarConfiguracionEstablecimientoCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- ============================================ -->
                <!-- CARD: ESTADO DEL SERVICIO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Estado del Servicio"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Servicio Activo -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Servicio Activo"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding ServicioActivo, Mode=TwoWay}"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <!-- Texto Cerrado (visible cuando está cerrado) -->
                        <StackLayout IsVisible="{Binding ServicioActivo, Converter={StaticResource InverseBoolConverter}}" Spacing="8">
                            <Label Text="Mensaje cuando está cerrado"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Editor Text="{Binding TextoCerrado}"
                                        FontFamily="Nunito"
                                        FontSize="14"
                                        TextColor="{DynamicResource Negro}"
                                        HeightRequest="80"
                                        AutoSize="TextChanges"/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: TIEMPOS Y TEXTOS -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Tiempos y Textos"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Tiempo de Entrega -->
                        <Grid ColumnDefinitions="*,100">
                            <Label Text="Tiempo de Entrega (min)"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding TiempoEntrega}"
                                       Keyboard="Numeric"
                                       MaxLength="3"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       HorizontalTextAlignment="Center"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <!-- Texto Extras/Ingredientes -->
                        <StackLayout Spacing="8">
                            <Label Text="Texto Extras"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding TextoIngredientes}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="Ej: Sin cebolla, Extra queso..."/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: IMPRESORAS -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Impresoras"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Impresora 1 -->
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <Label Text="Impresora 1"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding NombreImpresora}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="IP o nombre"/>
                            </Border>
                        </Grid>

                        <!-- Impresora 2 -->
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <Label Text="Impresora 2"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding NombreImpresora2}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="IP o nombre"/>
                            </Border>
                        </Grid>

                        <!-- Impresora 3 -->
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <Label Text="Impresora 3"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding NombreImpresora3}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="IP o nombre"/>
                            </Border>
                        </Grid>

                        <!-- Impresora 4 -->
                        <Grid ColumnDefinitions="80,*" ColumnSpacing="12">
                            <Label Text="Impresora 4"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding NombreImpresora4}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="IP o nombre"/>
                            </Border>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: SISTEMA DE PUNTOS -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Sistema de Puntos"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding SistemaPuntos, Mode=TwoWay}"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <!-- Opciones de puntos (visible cuando está activo) -->
                        <StackLayout IsVisible="{Binding SistemaPuntos}" Spacing="12">

                            <!-- Puntos por pedido -->
                            <Grid ColumnDefinitions="*,100">
                                <Label Text="Puntos por pedido"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry Text="{Binding PuntosPorPedido}"
                                           Keyboard="Numeric"
                                           MaxLength="3"
                                           FontFamily="Nunito"
                                           FontSize="14"
                                           TextColor="{DynamicResource Negro}"
                                           HorizontalTextAlignment="Center"
                                           BackgroundColor="Transparent"/>
                                </Border>
                            </Grid>

                            <!-- Puntos por euro -->
                            <Grid ColumnDefinitions="*,100">
                                <Label Text="Puntos por euro"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry Text="{Binding PuntosPorEuro}"
                                           Keyboard="Numeric"
                                           MaxLength="3"
                                           FontFamily="Nunito"
                                           FontSize="14"
                                           TextColor="{DynamicResource Negro}"
                                           HorizontalTextAlignment="Center"
                                           BackgroundColor="Transparent"/>
                                </Border>
                            </Grid>

                            <!-- Texto puntos -->
                            <StackLayout Spacing="8">
                                <Label Text="Texto informativo de puntos"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"/>
                                <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Editor Text="{Binding TextoPuntos}"
                                            FontFamily="Nunito"
                                            FontSize="14"
                                            TextColor="{DynamicResource Negro}"
                                            HeightRequest="80"
                                            AutoSize="TextChanges"/>
                                </Border>
                            </StackLayout>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: TICKET Y BOLSAS -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Ticket y Bolsas"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Tamaño Ticket -->
                        <Grid ColumnDefinitions="*,100">
                            <Label Text="Tamaño Ticket (mm)"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding TicketSize}"
                                       Keyboard="Numeric"
                                       MaxLength="3"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       HorizontalTextAlignment="Center"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <!-- Precio Bolsa -->
                        <Grid ColumnDefinitions="*,100">
                            <Label Text="Precio Bolsa (€)"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding PrecioBolsa}"
                                       Keyboard="Numeric"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       HorizontalTextAlignment="Center"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>

                        <!-- Rango Bolsa -->
                        <Grid ColumnDefinitions="*,100">
                            <Label Text="Una bolsa cada (uds)"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding RangoBolsa}"
                                       Keyboard="Numeric"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       HorizontalTextAlignment="Center"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: ENVÍO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,100">
                        <StackLayout VerticalOptions="Center">
                            <Label Text="Gastos de Envío"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="{DynamicResource Negro}"/>
                            <Label Text="Coste por envío a domicilio"
                                   FontFamily="Nunito"
                                   FontSize="12"
                                   TextColor="#888888"/>
                        </StackLayout>
                        <Border Grid.Column="1" BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="8,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Text="{Binding GastosEnvio}"
                                   Keyboard="Numeric"
                                   MaxLength="5"
                                   FontFamily="Nunito_bold"
                                   FontSize="16"
                                   TextColor="{StaticResource RojoMarca}"
                                   HorizontalTextAlignment="Center"
                                   BackgroundColor="Transparent"
                                   Placeholder="0.00"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: MÉTODOS DE PAGO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Métodos de Pago"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Efectivo -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border BackgroundColor="#E8F5E9" StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="💵" FontSize="18" VerticalOptions="Center" HorizontalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="Pago en Efectivo"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding Efectivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Datafono -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border BackgroundColor="#E3F2FD" StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="📱" FontSize="18" VerticalOptions="Center" HorizontalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="Pago con Datáfono"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding Datafono}"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarjeta -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border BackgroundColor="#FFF3E0" StrokeThickness="0" WidthRequest="40" HeightRequest="40">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="💳" FontSize="18" VerticalOptions="Center" HorizontalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1"
                                   Text="Pago con Tarjeta Online"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding Tarjeta}"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: DATOS DEL TICKET -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Datos del Ticket"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Nombre -->
                        <StackLayout Spacing="4">
                            <Label Text="Nombre"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding NombreTicket}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="Nombre del negocio"/>
                            </Border>
                        </StackLayout>

                        <!-- CIF -->
                        <StackLayout Spacing="4">
                            <Label Text="CIF"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding CIFTicket}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="B12345678"/>
                            </Border>
                        </StackLayout>

                        <!-- Dirección -->
                        <StackLayout Spacing="4">
                            <Label Text="Dirección"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding DireccionTicket}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="Calle, número, ciudad"/>
                            </Border>
                        </StackLayout>

                        <!-- Teléfono -->
                        <StackLayout Spacing="4">
                            <Label Text="Teléfono"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding TelefonoTicket}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Telephone"
                                       Placeholder="600 000 000"/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: CUENTA BANCARIA -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Cuenta Bancaria"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- IBAN -->
                        <StackLayout Spacing="4">
                            <Label Text="IBAN"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding IBAN}"
                                       FontFamily="Nunito"
                                       FontSize="14"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Text"
                                       Placeholder="ESXX-XXXX-XXXX-XXXX-XXXX-XXXX">
                                    <Entry.Behaviors>
                                        <mct:MaskedBehavior Mask="ESXX-XXXX-XXXX-XXXX-XXXX-XXXX"/>
                                    </Entry.Behaviors>
                                </Entry>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- Espaciado final -->
                

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
