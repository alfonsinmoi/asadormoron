<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Establecimientos.DetalleIngredienteView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ViewDetalleIngrediente"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Volver -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;"
                           FontSize="22"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Ingrediente"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Guardar -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Image Source="save.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CommandGuardar}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- ============================================ -->
                <!-- CARD: INFORMACIÓN -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">
                        <Label Text="Información"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Nombre -->
                        <StackLayout Spacing="6">
                            <Label Text="Nombre"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    Padding="14,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Nombre}"
                                       FontFamily="Nunito"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="Nombre del ingrediente"/>
                            </Border>
                        </StackLayout>

                        <!-- Precio -->
                        <StackLayout Spacing="6">
                            <Label Text="Precio"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    Padding="14,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Precio}"
                                       FontFamily="Nunito"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Numeric"
                                       Placeholder="0.00"/>
                            </Border>
                        </StackLayout>

                        <!-- Puntos -->
                        <StackLayout Spacing="6">
                            <Label Text="Puntos"
                                   FontFamily="Nunito"
                                   FontSize="13"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    Padding="14,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Puntos}"
                                       FontFamily="Nunito"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Numeric"
                                       MaxLength="5"
                                       Placeholder="0"/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: ESTADO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">

                        <!-- Icono -->
                        <Border Grid.Column="0"
                                BackgroundColor="#E8F5E9"
                                StrokeThickness="0"
                                WidthRequest="44"
                                HeightRequest="44">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Image Source="check.png"
                                   WidthRequest="22"
                                   HeightRequest="22"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
                        </Border>

                        <!-- Texto -->
                        <StackLayout Grid.Column="1"
                                     VerticalOptions="Center"
                                     Spacing="2">
                            <Label Text="Estado"
                                   FontFamily="Nunito_bold"
                                   FontSize="15"
                                   TextColor="{DynamicResource Negro}"/>
                            <Label Text="Activo o inactivo"
                                   FontFamily="Nunito"
                                   FontSize="12"
                                   TextColor="#888888"/>
                        </StackLayout>

                        <!-- Switch -->
                        <Switch Grid.Column="2"
                                IsToggled="{Binding Estado}"
                                OnColor="{StaticResource RojoMarca}"
                                VerticalOptions="Center"/>

                    </Grid>
                </Border>

                <!-- Espaciado final -->
                

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
