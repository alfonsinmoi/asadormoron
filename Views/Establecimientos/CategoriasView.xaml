<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Establecimientos.CategoriasView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Categorias"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Volver -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;"
                           FontSize="22"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título centrado -->
                <Label Grid.Column="1"
                       Text="Categorías"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Añadir -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Label Text="+"
                           FontSize="26"
                           FontFamily="Nunito_bold"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NuevaCategoriaCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- LISTADO DE CATEGORÍAS -->
        <!-- ============================================ -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding ListadoCategorias}"
                        SelectedItem="{Binding CategoriaSeleccionada, Mode=TwoWay}"
                        SelectionMode="Single"
                        ItemSizingStrategy="MeasureFirstItem"
                        Margin="0,8,0,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.Footer>
                
            </CollectionView.Footer>
            <CollectionView.EmptyView>
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Margin="16"
                        Padding="40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                        <Border BackgroundColor="#F5F5F5"
                                StrokeThickness="0"
                                Padding="16"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30"/>
                            </Border.StrokeShape>
                            <Image Source="categoria.png"
                                   WidthRequest="32"
                                   HeightRequest="32"
                                   Opacity="0.5"/>
                        </Border>
                        <Label Text="Sin categorías"
                               TextColor="{DynamicResource Negro}"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Pulsa + para crear tu primera categoría"
                               TextColor="#888888"
                               FontFamily="Nunito"
                               FontSize="14"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="16,0"
                            Padding="0"
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              Padding="16,14"
                              ColumnSpacing="14">

                            <!-- Icono categoría -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource RojoMarca}"
                                    StrokeThickness="0"
                                    WidthRequest="48"
                                    HeightRequest="48">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Image Source="categoria.png"
                                       WidthRequest="24"
                                       HeightRequest="24"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Border>

                            <!-- Info categoría -->
                            <StackLayout Grid.Column="1"
                                         Spacing="4"
                                         VerticalOptions="Center">
                                <Label Text="{Binding nombre}"
                                       FontFamily="Nunito_bold"
                                       FontSize="16"
                                       TextColor="{DynamicResource Negro}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                                <Label Text="{Binding tipo}"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="{StaticResource RojoMarca}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                            </StackLayout>

                            <!-- Flecha -->
                            <Label Grid.Column="2"
                                   Text="&#x203A;"
                                   FontSize="28"
                                   TextColor="#CCCCCC"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End"/>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
