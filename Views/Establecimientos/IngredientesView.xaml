<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Establecimientos.IngredientesView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ViewIngredientes"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Menú -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Image Source="menu.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Ingredientes"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Añadir -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Label Text="+"
                           FontSize="26"
                           FontFamily="Nunito_bold"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NuevoIngredienteCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding ListadoIngredientes}"
                        SelectionMode="Single"
                        SelectedItem="{Binding IngredienteSeleccioando, Mode=TwoWay}"
                        Margin="16,12,16,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="16,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="10" Opacity="0.08"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">

                            <!-- Icono -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource RojoMarca}"
                                    StrokeThickness="0"
                                    WidthRequest="44"
                                    HeightRequest="44">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Image Source="extras.png"
                                       WidthRequest="22"
                                       HeightRequest="22"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                            </Border>

                            <!-- Info -->
                            <StackLayout Grid.Column="1"
                                         VerticalOptions="Center"
                                         Spacing="2">
                                <Label Text="{Binding nombre}"
                                       FontFamily="Nunito_bold"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1"/>
                                <Label Text="{Binding precio, StringFormat='{0:N2}€'}"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="{StaticResource RojoMarca}"/>
                            </StackLayout>

                            <!-- Estado Switch -->
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding estado}"
                                    IsEnabled="False"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>

                            <!-- Flecha -->
                            <Image Grid.Column="3"
                                   Source="flecha.png"
                                   WidthRequest="16"
                                   HeightRequest="16"
                                   VerticalOptions="Center"
                                   Opacity="0.4"/>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Margin="0,20"
                        Padding="40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                        <Border BackgroundColor="#F5F5F5"
                                StrokeThickness="0"
                                Padding="16"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30"/>
                            </Border.StrokeShape>
                            <Image Source="extras.png"
                                   WidthRequest="32"
                                   HeightRequest="32"
                                   Opacity="0.5"/>
                        </Border>
                        <Label Text="Sin ingredientes"
                               TextColor="{DynamicResource Negro}"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Pulsa + para añadir uno nuevo"
                               TextColor="#888888"
                               FontFamily="Nunito"
                               FontSize="14"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.Footer>
                
            </CollectionView.Footer>
        </CollectionView>

    </Grid>

</ContentPage>
