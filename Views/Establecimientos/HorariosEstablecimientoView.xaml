<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Establecimientos.HorariosEstablecimientoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ViewHorarios"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Menú -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Image Source="menu.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Horarios"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Guardar -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Image Source="save.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GuardarConfiguracionEstablecimientoCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="12">

                <!-- Leyenda -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16,12">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*,80,80,50">
                        <Label Text="Turno"
                               FontFamily="Nunito_bold"
                               FontSize="12"
                               TextColor="#888888"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Inicio"
                               FontFamily="Nunito_bold"
                               FontSize="12"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2"
                               Text="Fin"
                               FontFamily="Nunito_bold"
                               FontSize="12"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="3"
                               Text="Activo"
                               FontFamily="Nunito_bold"
                               FontSize="12"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ============================================ -->
                <!-- LUNES -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Lunes"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioLunes, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoLunes}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinLunes, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoLunes}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoLunes}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioLunesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoLunesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinLunesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoLunesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoLunesTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- MARTES -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Martes"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioMartes, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMartes}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinMartes, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMartes}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoMartes}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioMartesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMartesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinMartesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMartesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoMartesTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- MIÉRCOLES -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Miércoles"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioMiercoles, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMiercoles}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinMiercoles, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMiercoles}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoMiercoles}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioMiercolesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMiercolesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinMiercolesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoMiercolesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoMiercolesTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- JUEVES -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Jueves"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioJueves, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoJueves}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinJueves, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoJueves}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoJueves}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioJuevesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoJuevesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinJuevesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoJuevesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoJuevesTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- VIERNES -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Viernes"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioViernes, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoViernes}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinViernes, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoViernes}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoViernes}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioViernesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoViernesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinViernesTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoViernesTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoViernesTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- SÁBADO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Sábado"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioSabado, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoSabado}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinSabado, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoSabado}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoSabado}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioSabadoTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoSabadoTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinSabadoTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoSabadoTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoSabadoTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- DOMINGO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">
                        <Label Text="Domingo"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"/>

                        <!-- Mañana -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Mañana"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioDomingo, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoDomingo}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinDomingo, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoDomingo}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoDomingo}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0F0F0"/>

                        <!-- Tarde -->
                        <Grid ColumnDefinitions="*,80,80,50" ColumnSpacing="8">
                            <Label Text="Tarde"
                                   FontFamily="Nunito"
                                   FontSize="14"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <TimePicker Grid.Column="1"
                                        Time="{Binding InicioDomingoTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoDomingoTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <TimePicker Grid.Column="2"
                                        Time="{Binding FinDomingoTarde, Mode=TwoWay}"
                                        Format="HH:mm"
                                        IsEnabled="{Binding ActivoDomingoTarde}"
                                        FontSize="13"
                                        TextColor="{DynamicResource Negro}"/>
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding ActivoDomingoTarde}"
                                    IsEnabled="{Binding ServicioActivo}"
                                    OnColor="{StaticResource RojoMarca}"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- Espaciado final -->
                

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
