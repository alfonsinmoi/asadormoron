<?xml version="1.0" encoding="utf-8" ?>
<popup:PopupPage
    x:Class="AsadorMoron.Views.Establecimientos.PopupPageInfoUsuario"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:popup="clr-namespace:Mopups.Pages;assembly=Mopups"
    BackgroundColor="#80000000">

    <popup:PopupPage.Content>
        <Border Margin="24"
                BackgroundColor="White"
                StrokeThickness="0"
                MaximumWidthRequest="400"
                HorizontalOptions="Center"
                VerticalOptions="Center">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.3"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*" Padding="0">

                <!-- HEADER -->
                <Border Grid.Row="0"
                        BackgroundColor="#C41E3A"
                        StrokeThickness="0"
                        Padding="20,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="24,24,0,0"/>
                    </Border.StrokeShape>

                    <StackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="&#x1F464;"
                               FontSize="32"
                               HorizontalOptions="Center"/>
                        <Label Text="Datos del Usuario"
                               FontFamily="Nunito_bold"
                               FontSize="20"
                               TextColor="White"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>

                <!-- CONTENIDO -->
                <StackLayout Grid.Row="1" Padding="20" Spacing="12">

                    <!-- Nombre -->
                    <Border BackgroundColor="#F5F5F5"
                            StrokeThickness="0"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#C41E3A"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F464;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Nombre"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="txtNombre"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"/>
                            </StackLayout>
                        </Grid>
                    </Border>

                    <!-- Dirección -->
                    <Border BackgroundColor="#F5F5F5"
                            StrokeThickness="0"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#C41E3A"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4CD;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Dirección"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="txtDireccion"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"
                                       LineBreakMode="WordWrap"/>
                            </StackLayout>
                        </Grid>
                    </Border>

                    <!-- Zona -->
                    <Border BackgroundColor="#F5F5F5"
                            StrokeThickness="0"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#C41E3A"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F3D8;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Zona"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="txtZona"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"/>
                            </StackLayout>
                        </Grid>
                    </Border>

                    <!-- Teléfono -->
                    <Border BackgroundColor="#F5F5F5"
                            StrokeThickness="0"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#C41E3A"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x1F4DE;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Teléfono"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="txtTelefono"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"/>
                            </StackLayout>
                        </Grid>
                    </Border>

                    <!-- Email -->
                    <Border BackgroundColor="#F5F5F5"
                            StrokeThickness="0"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border BackgroundColor="#C41E3A"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="&#x2709;"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Email"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <Label x:Name="txtEmail"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"
                                       LineBreakMode="TailTruncation"/>
                            </StackLayout>
                        </Grid>
                    </Border>

                </StackLayout>

            </Grid>
        </Border>
    </popup:PopupPage.Content>
</popup:PopupPage>
