<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Establecimientos.DetalleComidaView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:tabView="clr-namespace:Syncfusion.Maui.TabView;assembly=Syncfusion.Maui.TabView"
    x:Name="ComidaDetalleView"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Volver -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2190;"
                           FontSize="22"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="{Binding Nombre, TargetNullValue='Nuevo producto', FallbackValue='Nuevo producto'}"
                       FontFamily="Nunito_bold"
                       FontSize="18"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       LineBreakMode="TailTruncation"
                       MaxLines="1"/>

                <!-- Botón Guardar -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Image Source="save.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CommandGuardar}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1">
            <StackLayout Spacing="16" Padding="16,16,16,32">

                <!-- CARD: IMAGEN -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        HeightRequest="200">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid>
                        <!-- Imagen -->
                        <ff:CachedImage Source="{Binding Imagen}"
                                        Aspect="AspectFit"
                                        LoadingPlaceholder="logo_producto.png"
                                        ErrorPlaceholder="logo_producto.png"
                                        DownsampleToViewSize="True"
                                        RetryCount="3"
                                        RetryDelay="250"/>

                        <!-- Overlay con botón cambiar imagen -->
                        <Border BackgroundColor="#50000000"
                                StrokeThickness="0"
                                VerticalOptions="End"
                                HeightRequest="48">
                            <StackLayout Orientation="Horizontal"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="10">
                                <Image Source="camara.png"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center"/>
                                <Label Text="Cambiar imagen"
                                       TextColor="White"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                            </StackLayout>
                        </Border>

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CmdCambiaImagen}"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!-- CARD: INFORMACIÓN BÁSICA -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">

                        <Label Text="Información básica"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Nombre con idiomas -->
                        <StackLayout Spacing="8">
                            <Label Text="Nombre"
                                   FontFamily="Nunito_bold"
                                   FontSize="13"
                                   TextColor="#666666"/>
                            <tabView:SfTabView TabBarPlacement="Top"
                                               TabBarHeight="40"
                                               HeightRequest="90"
                                               IndicatorBackground="{StaticResource RojoMarca}"
                                               IndicatorPlacement="Bottom">
                                <tabView:SfTabItem ImageSource="spain.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Entry Text="{Binding Nombre}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                                <tabView:SfTabItem ImageSource="english.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Entry Text="{Binding Nombre_eng}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                                <tabView:SfTabItem ImageSource="germany.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Entry Text="{Binding Nombre_ger}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                                <tabView:SfTabItem ImageSource="france.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Entry Text="{Binding Nombre_fr}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                            </tabView:SfTabView>
                        </StackLayout>

                        <!-- Categoría -->
                        <StackLayout Spacing="8">
                            <Label Text="Categoría"
                                   FontFamily="Nunito_bold"
                                   FontSize="13"
                                   TextColor="#666666"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Picker Title="Seleccione una categoría"
                                        ItemDisplayBinding="{Binding nombre}"
                                        ItemsSource="{Binding ListadoCategorias}"
                                        SelectedItem="{Binding CategoriaSeleccionada}"
                                        TextColor="{DynamicResource Negro}"
                                        TitleColor="#BBBBBB"
                                        FontFamily="Nunito"
                                        BackgroundColor="Transparent"
                                        HeightRequest="48"/>
                            </Border>
                        </StackLayout>

                        <!-- Precios -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackLayout Grid.Column="0" Spacing="8">
                                <Label Text="Precio"
                                       FontFamily="Nunito_bold"
                                       FontSize="13"
                                       TextColor="#666666"/>
                                <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Entry Placeholder="0.00"
                                           Text="{Binding Precio}"
                                           Keyboard="Numeric"
                                           TextColor="{DynamicResource Negro}"
                                           FontFamily="Nunito"
                                           FontSize="15"
                                           BackgroundColor="Transparent"
                                           HeightRequest="48"/>
                                </Border>
                            </StackLayout>
                            <StackLayout Grid.Column="1" Spacing="8" IsVisible="{Binding TieneLocal}">
                                <Label Text="Precio local"
                                       FontFamily="Nunito_bold"
                                       FontSize="13"
                                       TextColor="#666666"/>
                                <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Entry Placeholder="0.00"
                                           Text="{Binding PrecioLocal}"
                                           Keyboard="Numeric"
                                           TextColor="{DynamicResource Negro}"
                                           FontFamily="Nunito"
                                           FontSize="15"
                                           BackgroundColor="Transparent"
                                           HeightRequest="48"/>
                                </Border>
                            </StackLayout>
                        </Grid>

                        <!-- Descripción con idiomas -->
                        <StackLayout Spacing="8">
                            <Label Text="Descripción"
                                   FontFamily="Nunito_bold"
                                   FontSize="13"
                                   TextColor="#666666"/>
                            <tabView:SfTabView TabBarPlacement="Top"
                                               TabBarHeight="40"
                                               HeightRequest="140"
                                               IndicatorBackground="{StaticResource RojoMarca}"
                                               IndicatorPlacement="Bottom">
                                <tabView:SfTabItem ImageSource="spain.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Editor Text="{Binding Descripcion}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HeightRequest="60"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                                <tabView:SfTabItem ImageSource="english.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Editor Text="{Binding Descripcion_eng}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HeightRequest="60"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                                <tabView:SfTabItem ImageSource="germany.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Editor Text="{Binding Descripcion_ger}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HeightRequest="60"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                                <tabView:SfTabItem ImageSource="france.png">
                                    <tabView:SfTabItem.Content>
                                        <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Editor Text="{Binding Descripcion_fr}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HeightRequest="60"/>
                                        </Border>
                                    </tabView:SfTabItem.Content>
                                </tabView:SfTabItem>
                            </tabView:SfTabView>
                        </StackLayout>

                    </StackLayout>
                </Border>

                <!-- CARD: CONFIGURACIÓN -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">

                        <Label Text="Configuración"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Estado -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="Estado" FontFamily="Nunito_bold" FontSize="14" TextColor="{DynamicResource Negro}"/>
                                <Label Text="Producto activo/inactivo" FontFamily="Nunito" FontSize="12" TextColor="#888888"/>
                            </StackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding Estado}" OnColor="{StaticResource RojoMarca}" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#EEEEEE"/>

                        <!-- Visible para fuera -->
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding TieneLocal}">
                            <StackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="Visible para fuera" FontFamily="Nunito_bold" FontSize="14" TextColor="{DynamicResource Negro}"/>
                                <Label Text="Mostrar en pedidos a domicilio" FontFamily="Nunito" FontSize="12" TextColor="#888888"/>
                            </StackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding VistaEnvios}" OnColor="{StaticResource RojoMarca}" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#EEEEEE" IsVisible="{Binding TieneLocal}"/>

                        <!-- Visible para local -->
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding TieneLocal}">
                            <StackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="Visible para local" FontFamily="Nunito_bold" FontSize="14" TextColor="{DynamicResource Negro}"/>
                                <Label Text="Mostrar en pedidos en local" FontFamily="Nunito" FontSize="12" TextColor="#888888"/>
                            </StackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding VistaLocal}" OnColor="{StaticResource RojoMarca}" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#EEEEEE" IsVisible="{Binding TieneLocal}"/>

                        <!-- Por encargo -->
                        <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding TieneEncargos}">
                            <StackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="Por encargo" FontFamily="Nunito_bold" FontSize="14" TextColor="{DynamicResource Negro}"/>
                                <Label Text="Requiere pedido anticipado" FontFamily="Nunito" FontSize="12" TextColor="#888888"/>
                            </StackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding PorEncargo}" OnColor="{StaticResource RojoMarca}" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#EEEEEE" IsVisible="{Binding TieneEncargos}"/>

                        <!-- Nº Ingredientes y Fuerza -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackLayout Grid.Column="0" Spacing="8">
                                <Label Text="Nº Ingredientes" FontFamily="Nunito_bold" FontSize="13" TextColor="#666666"/>
                                <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Entry Text="{Binding NumeroIngredientes}" Keyboard="Numeric" MaxLength="3" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="15" BackgroundColor="Transparent" HeightRequest="48"/>
                                </Border>
                            </StackLayout>
                            <StackLayout Grid.Column="1" Spacing="8">
                                <Label Text="Ing. obligatorios" FontFamily="Nunito_bold" FontSize="13" TextColor="#666666"/>
                                <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8" HeightRequest="48" VerticalOptions="Start">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <Switch IsToggled="{Binding FuerzaIngredientes}" OnColor="{StaticResource RojoMarca}" HorizontalOptions="Start"/>
                                </Border>
                            </StackLayout>
                        </Grid>

                        <!-- Puntos -->
                        <StackLayout Spacing="8" IsVisible="{Binding SistemaPuntos}">
                            <Label Text="Puntos" FontFamily="Nunito_bold" FontSize="13" TextColor="#666666"/>
                            <Border BackgroundColor="#FAFAFA" StrokeThickness="1" Stroke="#E0E0E0" Padding="12,0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Entry Text="{Binding Puntos}" Keyboard="Numeric" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="15" BackgroundColor="Transparent" HeightRequest="48"/>
                            </Border>
                        </StackLayout>

                    </StackLayout>
                </Border>

                <!-- CARD: OPCIONES -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="20"
                        IsVisible="{Binding EsComida}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Opciones"
                                   FontFamily="Nunito_bold"
                                   FontSize="18"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1"
                                    BackgroundColor="{StaticResource RojoMarca}"
                                    StrokeThickness="0"
                                    WidthRequest="36"
                                    HeightRequest="36">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="+" FontSize="22" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CmdNuevaOpcion}"/>
                                </Border.GestureRecognizers>
                            </Border>
                        </Grid>

                        <!-- Header opciones -->
                        <Grid ColumnDefinitions="*,70,70" Padding="0,8">
                            <Label Text="Opción" FontFamily="Nunito" FontSize="12" TextColor="#888888"/>
                            <Label Grid.Column="1" Text="Precio" FontFamily="Nunito" FontSize="12" TextColor="#888888" HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="Puntos" FontFamily="Nunito" FontSize="12" TextColor="#888888" HorizontalTextAlignment="Center" IsVisible="{Binding SistemaPuntos}"/>
                        </Grid>

                        <!-- Lista de opciones -->
                        <StackLayout BindableLayout.ItemsSource="{Binding ListadoOpciones}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Grid ColumnDefinitions="*,70,70" ColumnSpacing="8">
                                            <Entry Text="{Binding opcion, Mode=TwoWay}" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent"/>
                                            <Entry Grid.Column="1" Text="{Binding precio, StringFormat='{0:N2}', Mode=TwoWay}" Keyboard="Numeric" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HorizontalTextAlignment="Center"/>
                                            <Entry Grid.Column="2" Text="{Binding puntos}" Keyboard="Numeric" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HorizontalTextAlignment="Center" IsVisible="{Binding Path=BindingContext.SistemaPuntos, Source={x:Reference Name=ComidaDetalleView}}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>

                    </StackLayout>
                </Border>

                <!-- CARD: ALÉRGENOS -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="20"
                        IsVisible="{Binding EsComida}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">

                        <Label Text="Alérgenos"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               TextColor="{DynamicResource Negro}"/>

                        <Grid ColumnDefinitions="*,*,*,*,*"
                              RowDefinitions="55,55,55"
                              RowSpacing="8"
                              ColumnSpacing="8">
                            <Image Grid.Row="0" Grid.Column="0" Source="{Binding Altramuces}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaAltramuces}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="0" Grid.Column="1" Source="{Binding Apio}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaApio}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="0" Grid.Column="2" Source="{Binding Cacahuetes}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaCacahuetes}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="0" Grid.Column="3" Source="{Binding Crustaceos}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaCrustaceos}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="0" Grid.Column="4" Source="{Binding FrutosSecos}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaFrutosSecos}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="1" Grid.Column="0" Source="{Binding Gluten}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaGluten}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="1" Grid.Column="1" Source="{Binding Huevos}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaHuevos}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="1" Grid.Column="2" Source="{Binding Lacteos}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaLacteos}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="1" Grid.Column="3" Source="{Binding Moluscos}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaMoluscos}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="1" Grid.Column="4" Source="{Binding Mostaza}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaMostaza}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="2" Grid.Column="0" Source="{Binding Pescado}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaPescado}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="2" Grid.Column="1" Source="{Binding Sesamo}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaSesamo}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="2" Grid.Column="2" Source="{Binding Soja}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaSoja}"/></Image.GestureRecognizers></Image>
                            <Image Grid.Row="2" Grid.Column="3" Source="{Binding Sulfitos}" HeightRequest="45"><Image.GestureRecognizers><TapGestureRecognizer Command="{Binding CmdCambiaSulfitos}"/></Image.GestureRecognizers></Image>
                        </Grid>

                    </StackLayout>
                </Border>

                <!-- CARD: INGREDIENTES -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="20"
                        IsVisible="{Binding EsComida}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="12">

                        <Label Text="Ingredientes"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               TextColor="{DynamicResource Negro}"/>

                        <StackLayout BindableLayout.ItemsSource="{Binding ListadoIngredientes}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#FAFAFA" StrokeThickness="0" Padding="12,8">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto,*,80,Auto" ColumnSpacing="10">
                                            <CheckBox IsChecked="{Binding seleccionado}" Color="{StaticResource RojoMarca}" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding nombre}" FontFamily="Nunito" FontSize="14" TextColor="{DynamicResource Negro}" VerticalOptions="Center"/>
                                            <Entry Grid.Column="2" Text="{Binding precio}" Keyboard="Numeric" TextColor="{DynamicResource Negro}" FontFamily="Nunito" FontSize="14" BackgroundColor="Transparent" HorizontalTextAlignment="End"/>
                                            <Label Grid.Column="3" Text="€" FontFamily="Nunito" FontSize="14" TextColor="#888888" VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </StackLayout>

                    </StackLayout>
                </Border>

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
