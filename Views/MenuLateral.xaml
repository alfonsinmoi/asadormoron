<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.MenuLateral"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:xct="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
    Title=" "
    IconImageSource="menu.png"
    BackgroundColor="#F5F5F5"
    x:Name="miMenu">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============================================ -->
        <!-- HEADER CON PERFIL -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource RojoMarca}"
                StrokeThickness="0"
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,32,32"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.15"/>
            </Border.Shadow>

            <StackLayout Padding="24,50,24,28" Spacing="16">

                <!-- Avatar y nombre -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">

                    <!-- Foto de perfil -->
                    <Grid Grid.Column="0">
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                WidthRequest="72"
                                HeightRequest="72">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="36"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.2"/>
                            </Border.Shadow>
                            <ff:CachedImage Source="{Binding Foto}"
                                            Aspect="AspectFill"
                                            WidthRequest="72"
                                            HeightRequest="72">
                                <ff:CachedImage.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PerfilCommand}"/>
                                </ff:CachedImage.GestureRecognizers>
                            </ff:CachedImage>
                        </Border>
                    </Grid>

                    <!-- Nombre y saludo -->
                    <StackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 Spacing="2">
                        <Label Text="Hola,"
                               FontFamily="Nunito"
                               FontSize="14"
                               TextColor="#FFFFFFBB"/>
                        <Label Text="{Binding Nombre}"
                               FontFamily="Nunito_bold"
                               FontSize="20"
                               TextColor="White"
                               LineBreakMode="TailTruncation"
                               MaxLines="1"/>
                        <Label Text="Ver mi perfil ›"
                               FontFamily="Nunito"
                               FontSize="13"
                               TextColor="White"
                               Opacity="0.8"
                               IsVisible="{Binding Logado}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding PerfilCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </StackLayout>
                </Grid>

            </StackLayout>
        </Border>

        <!-- ============================================ -->
        <!-- LISTA DE MENU -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1" Padding="16,20,16,10">
            <StackLayout x:Name="navigationDrawerList"
                         Spacing="8"
                         BindableLayout.ItemsSource="{Binding ListaMenuByRol}">

                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <xct:Expander>
                            <xct:Expander.Header>
                                <Border BackgroundColor="White"
                                        StrokeThickness="0"
                                        Padding="14,12">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.06"/>
                                    </Border.Shadow>

                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                        <!-- Icono con fondo rojo -->
                                        <Border Grid.Column="0"
                                                BackgroundColor="{StaticResource RojoMarca}"
                                                StrokeThickness="0"
                                                WidthRequest="44"
                                                HeightRequest="44">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Image Source="{Binding IconSource}"
                                                   WidthRequest="22"
                                                   HeightRequest="22"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center"/>
                                        </Border>

                                        <!-- Titulo -->
                                        <Label Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontFamily="Nunito_bold"
                                               FontSize="15"
                                               TextColor="#333333"
                                               VerticalOptions="Center"/>

                                        <!-- Flecha expandir -->
                                        <Border Grid.Column="2"
                                                BackgroundColor="{StaticResource RojoMarca}"
                                                StrokeThickness="0"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                IsVisible="{Binding TieneHijos}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Image Source="expand.png"
                                                   WidthRequest="14"
                                                   HeightRequest="14"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center">
                                                <Image.Triggers>
                                                    <DataTrigger TargetType="Image"
                                                                 Binding="{Binding Source={RelativeSource AncestorType={x:Type xct:Expander}}, Path=IsExpanded}"
                                                                 Value="True">
                                                        <Setter Property="Source" Value="collapse.png"/>
                                                    </DataTrigger>
                                                </Image.Triggers>
                                            </Image>
                                        </Border>
                                    </Grid>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Path=BindingContext.ItemSelected, Source={x:Reference Name=miMenu}}"
                                                              CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </xct:Expander.Header>

                            <!-- Submenu (hijos) -->
                            <StackLayout Margin="0,6,0,0"
                                         Spacing="4"
                                         BindableLayout.ItemsSource="{Binding Hijos}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="{StaticResource RojoMarca}"
                                                StrokeThickness="0"
                                                Margin="20,0,0,0"
                                                Padding="14,12">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                                <Image Grid.Column="0"
                                                       Source="{Binding IconSource}"
                                                       WidthRequest="20"
                                                       HeightRequest="20"
                                                       VerticalOptions="Center"/>
                                                <Label Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontFamily="Nunito"
                                                       FontSize="14"
                                                       TextColor="White"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Path=BindingContext.ItemSelected, Source={x:Reference Name=miMenu}}"
                                                                      CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </xct:Expander>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>
        </ScrollView>

        <!-- ============================================ -->
        <!-- FOOTER -->
        <!-- ============================================ -->
        <StackLayout Grid.Row="2" Padding="16,8,16,20" Spacing="12">

            <!-- Contador usuarios (solo admin) -->
            <Border IsVisible="{Binding EsAdmin}"
                    BackgroundColor="{StaticResource RojoMarca}"
                    StrokeThickness="0"
                    Padding="16,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.25"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ContadorCommand}"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Label Grid.Column="0"
                           Text="&#x1F465;"
                           FontSize="20"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="Usuarios registrados"
                           FontFamily="Nunito"
                           FontSize="13"
                           TextColor="White"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="2"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="12,6">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="{Binding TotalUsuarios}"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{StaticResource RojoMarca}"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Version -->
            <Label Text="{Binding Version}"
                   FontFamily="Nunito"
                   FontSize="12"
                   TextColor="#AAAAAA"
                   HorizontalTextAlignment="Center"/>

        </StackLayout>

    </Grid>

</ContentPage>
