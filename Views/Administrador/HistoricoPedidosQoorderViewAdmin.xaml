<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Administrador.HistoricoPedidosViewAdmin"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    x:Name="HistoricoPedidosAdmin"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- ============================================ -->
        <!-- HEADER -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="16,12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="8" Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Botón Menú -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="&#x2630;"
                           FontSize="22"
                           TextColor="{DynamicResource Negro}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Border>

                <!-- Título -->
                <StackLayout Grid.Column="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="2">
                    <Label Text="Historico"
                           FontFamily="Nunito_bold"
                           FontSize="18"
                           TextColor="#333333"
                           HorizontalOptions="Center"/>
                    <Label Text="Pedidos"
                           FontFamily="Nunito"
                           FontSize="11"
                           TextColor="#888888"
                           HorizontalOptions="Center"/>
                </StackLayout>

                <!-- Botón Exportar -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding cmdExport}"/>
                    </Border.GestureRecognizers>
                    <Image Source="excel.png"
                           HeightRequest="22"
                           WidthRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- PANEL DE FILTROS -->
        <!-- ============================================ -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="16,12,16,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,2" Radius="6" Opacity="0.08"/>
            </Border.Shadow>

            <StackLayout Spacing="0">
                <!-- Cabecera expandible -->
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,12">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleDetailCommand}"/>
                    </Grid.GestureRecognizers>

                    <Border BackgroundColor="{StaticResource RojoMarca}"
                            StrokeThickness="0"
                            WidthRequest="36"
                            HeightRequest="36">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="&#x1F50D;"
                               FontSize="16"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Label Grid.Column="1"
                           Text="Filtros de Busqueda"
                           FontFamily="Nunito_bold"
                           FontSize="14"
                           TextColor="#333333"
                           VerticalOptions="Center"
                           Margin="12,0,0,0"/>

                    <Label Grid.Column="2"
                           Text="&#x25BC;"
                           FontSize="12"
                           TextColor="#888888"
                           VerticalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger Binding="{Binding IsDetailVisible}"
                                         TargetType="Label"
                                         Value="True">
                                <Setter Property="Text" Value="&#x25B2;"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Grid>

                <!-- Contenido filtros -->
                <StackLayout IsVisible="{Binding IsDetailVisible}"
                             Padding="14,0,14,14"
                             Spacing="10">

                    <!-- Fila: Desde - Hasta -->
                    <Grid ColumnDefinitions="*,12,*">
                        <StackLayout Spacing="4">
                            <Label Text="Desde"
                                   FontFamily="Nunito"
                                   FontSize="11"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F5F5F5"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <DatePicker Date="{Binding Desde}"
                                            FontFamily="Nunito"
                                            FontSize="12"
                                            TextColor="#333333"/>
                            </Border>
                        </StackLayout>

                        <StackLayout Grid.Column="2" Spacing="4">
                            <Label Text="Hasta"
                                   FontFamily="Nunito"
                                   FontSize="11"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F5F5F5"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <DatePicker Date="{Binding Hasta}"
                                            FontFamily="Nunito"
                                            FontSize="12"
                                            TextColor="#333333"/>
                            </Border>
                        </StackLayout>
                    </Grid>

                    <!-- Repartidor -->
                    <StackLayout Spacing="4">
                        <Label Text="Repartidor"
                               FontFamily="Nunito"
                               FontSize="11"
                               TextColor="#888888"/>
                        <Border BackgroundColor="#F5F5F5"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                Padding="4,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Picker ItemsSource="{Binding Repartidores}"
                                    ItemDisplayBinding="{Binding nombre}"
                                    SelectedItem="{Binding RepartidorSeleccionado}"
                                    FontFamily="Nunito"
                                    FontSize="12"
                                    TextColor="#333333"/>
                        </Border>
                    </StackLayout>

                    <!-- Fila: Zona - Tipo -->
                    <Grid ColumnDefinitions="*,12,*">
                        <StackLayout Spacing="4">
                            <Label Text="Zona"
                                   FontFamily="Nunito"
                                   FontSize="11"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F5F5F5"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    Padding="4,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Picker ItemsSource="{Binding Zonas}"
                                        ItemDisplayBinding="{Binding nombre}"
                                        SelectedItem="{Binding ZonaSeleccionada}"
                                        FontFamily="Nunito"
                                        FontSize="12"
                                        TextColor="#333333"/>
                            </Border>
                        </StackLayout>

                        <StackLayout Grid.Column="2" Spacing="4">
                            <Label Text="Tipo"
                                   FontFamily="Nunito"
                                   FontSize="11"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F5F5F5"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    Padding="4,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Picker ItemsSource="{Binding Tipos}"
                                        SelectedItem="{Binding TipoSeleccionado}"
                                        FontFamily="Nunito"
                                        FontSize="12"
                                        TextColor="#333333"/>
                            </Border>
                        </StackLayout>
                    </Grid>

                    <!-- Fila: Tipo Pago - Horario -->
                    <Grid ColumnDefinitions="*,12,*">
                        <StackLayout Spacing="4">
                            <Label Text="Tipo Pago"
                                   FontFamily="Nunito"
                                   FontSize="11"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F5F5F5"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    Padding="4,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Picker ItemsSource="{Binding TiposPago}"
                                        SelectedItem="{Binding TipoPago}"
                                        FontFamily="Nunito"
                                        FontSize="12"
                                        TextColor="#333333"/>
                            </Border>
                        </StackLayout>

                        <StackLayout Grid.Column="2" Spacing="4">
                            <Label Text="Horario"
                                   FontFamily="Nunito"
                                   FontSize="11"
                                   TextColor="#888888"/>
                            <Border BackgroundColor="#F5F5F5"
                                    Stroke="#E0E0E0"
                                    StrokeThickness="1"
                                    Padding="4,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Picker ItemsSource="{Binding Tiempos}"
                                        SelectedItem="{Binding TiempoSeleccionado}"
                                        FontFamily="Nunito"
                                        FontSize="12"
                                        TextColor="#333333"/>
                            </Border>
                        </StackLayout>
                    </Grid>

                    <!-- Tipo Pedido -->
                    <StackLayout Spacing="4">
                        <Label Text="Tipo Pedido"
                               FontFamily="Nunito"
                               FontSize="11"
                               TextColor="#888888"/>
                        <Border BackgroundColor="#F5F5F5"
                                Stroke="#E0E0E0"
                                StrokeThickness="1"
                                Padding="4,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Picker ItemsSource="{Binding Autos}"
                                    SelectedItem="{Binding AutoSeleccionado}"
                                    FontFamily="Nunito"
                                    FontSize="12"
                                    TextColor="#333333"/>
                        </Border>
                    </StackLayout>

                    <!-- Botones -->
                    <Grid ColumnDefinitions="*,10,*" Margin="0,6,0,0">
                        <Button Text="Ver Mas"
                                Command="{Binding cmdMas}"
                                FontFamily="Nunito_bold"
                                FontSize="13"
                                BackgroundColor="{StaticResource RojoMarca}"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="42"/>
                        <Button Grid.Column="2"
                                Text="Ver Todo"
                                Command="{Binding cmdMas}"
                                FontFamily="Nunito_bold"
                                FontSize="13"
                                BackgroundColor="#333333"
                                TextColor="White"
                                CornerRadius="10"
                                HeightRequest="42"/>
                    </Grid>
                </StackLayout>
            </StackLayout>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL - SOLO PEDIDOS -->
        <!-- ============================================ -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Listado}"
                        ItemSizingStrategy="MeasureFirstItem"
                        Margin="16,12,16,0">
            <CollectionView.EmptyView>
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="24"
                        Margin="0,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <StackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="&#x1F4ED;"
                               FontSize="36"
                               HorizontalOptions="Center"/>
                        <Label Text="No hay pedidos"
                               FontFamily="Nunito"
                               FontSize="14"
                               TextColor="#888888"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="White"
                            StrokeThickness="0"
                            Margin="0,0,0,8"
                            Padding="12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,1" Radius="4" Opacity="0.06"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Path=BindingContext.InfoUsuarioPedidoCommand, Source={x:Reference Name=HistoricoPedidosAdmin}}"
                                                  CommandParameter="{Binding codigoPedido}"/>
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger Binding="{Binding tipo}"
                                         TargetType="Border"
                                         Value="2">
                                <Setter Property="BackgroundColor" Value="#F0F0F0"/>
                            </DataTrigger>
                        </Border.Triggers>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <!-- Foto repartidor -->
                            <Grid WidthRequest="60" HeightRequest="60">
                                    <ff:CachedImage Aspect="AspectFill"
                                                    WidthRequest="30"
                                                    HeightRequest="30"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center"
                                                    IsVisible="{Binding repartidor}"
                                                    Source="{Binding FotoRepartidor}">
                                    </ff:CachedImage>
                                <Image Source="{Binding ImagenEstadoPedido}"
                                       WidthRequest="60"
                                       HeightRequest="60"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Grid>

                            <!-- Info pedido -->
                            <StackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding nombreUsuario}"
                                       FontFamily="Nunito_bold"
                                       FontSize="14"
                                       TextColor="#333333"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding horaEntrega, StringFormat='{0:dd/MM/yyyy - HH:mm}'}"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#888888"/>
                                <!-- Observaciones/Comentario (solo visible si tiene contenido) -->
                                <Label Text="{Binding comentario}"
                                       FontFamily="Nunito"
                                       FontSize="11"
                                       TextColor="#FF9800"
                                       FontAttributes="Italic"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2"
                                       IsVisible="{Binding comentario, Converter={StaticResource StringEmptyToBooleanConverter}}"/>
                                <StackLayout Orientation="Horizontal" Spacing="6">
                                    <Border BackgroundColor="#333333"
                                            StrokeThickness="0"
                                            Padding="6,2">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding tipoPago, Converter={StaticResource SubstringConverter}, ConverterParameter='0,1'}"
                                               FontFamily="Nunito_bold"
                                               FontSize="9"
                                               TextColor="White"/>
                                    </Border>
                                    <Border BackgroundColor="{StaticResource RojoMarca}"
                                            StrokeThickness="0"
                                            Padding="6,2">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding tipoVenta}"
                                               FontFamily="Nunito_bold"
                                               FontSize="9"
                                               TextColor="White"/>
                                    </Border>
                                </StackLayout>
                            </StackLayout>

                            <!-- Precio -->
                            <StackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding precioTotalPedido, StringFormat='{0:N2}€'}"
                                       FontFamily="Nunito_bold"
                                       FontSize="16"
                                       TextColor="{StaticResource RojoMarca}"
                                       HorizontalTextAlignment="End"/>
                                <Label Text="{Binding codigoPedido}"
                                       FontFamily="Nunito"
                                       FontSize="10"
                                       TextColor="#AAAAAA"
                                       HorizontalTextAlignment="End"/>
                                <ImageButton Source="printer.png"
                                             BackgroundColor="Transparent"
                                             Command="{Binding Path=BindingContext.PrintCommand, Source={x:Reference Name=HistoricoPedidosAdmin}}"
                                             CommandParameter="{Binding codigoPedido}"
                                             HeightRequest="22"
                                             WidthRequest="22"
                                             IsVisible="{OnPlatform WinUI=true,Default=false}"
                                             HorizontalOptions="End"/>
                            </StackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ============================================ -->
        <!-- SECCION GASTOS (visible solo si hay gastos) -->
        <!-- ============================================ -->
        <StackLayout Grid.Row="3"
                     Margin="16,8,16,0"
                     Spacing="8"
                     IsVisible="{Binding Gastos.Count, Converter={StaticResource IntToBoolConverter}}">

            <!-- Título Gastos -->
            <Border BackgroundColor="#333333"
                    StrokeThickness="0"
                    Padding="12,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Label Text="&#x1F4B0; GASTOS E INGRESOS EXTRA"
                       FontFamily="Nunito_bold"
                       FontSize="12"
                       TextColor="White"/>
            </Border>

            <!-- Lista de Gastos con BindableLayout -->
            <StackLayout BindableLayout.ItemsSource="{Binding Gastos}"
                         Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,1" Radius="4" Opacity="0.06"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border BackgroundColor="#F5F5F5"
                                        StrokeThickness="0"
                                        WidthRequest="44"
                                        HeightRequest="44">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="22"/>
                                    </Border.StrokeShape>
                                    <ff:CachedImage Aspect="AspectFill"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    Source="{Binding fotoRepartidor}">
                                        <ff:CachedImage.Clip>
                                            <EllipseGeometry Center="22,22" RadiusX="22" RadiusY="22"/>
                                        </ff:CachedImage.Clip>
                                    </ff:CachedImage>
                                </Border>

                                <StackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding nombreRepartidor}"
                                           FontFamily="Nunito_bold"
                                           FontSize="14"
                                           TextColor="#333333"/>
                                    <Label Text="{Binding concepto}"
                                           FontFamily="Nunito"
                                           FontSize="11"
                                           TextColor="#888888"
                                           IsVisible="{Binding concepto, Converter={StaticResource StringEmptyToBooleanConverter}}"
                                           LineBreakMode="TailTruncation"/>
                                </StackLayout>

                                <Label Grid.Column="2"
                                       Text="{Binding precio, StringFormat='{0:N2}€'}"
                                       FontFamily="Nunito_bold"
                                       FontSize="15"
                                       TextColor="#4CAF50"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger Binding="{Binding precio, Converter={StaticResource isNegativeConverter}}"
                                                     TargetType="Label"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="#F44336"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </StackLayout>
        </StackLayout>

        <!-- ============================================ -->
        <!-- FOOTER TOTALES -->
        <!-- ============================================ -->
        <Border Grid.Row="4"
                BackgroundColor="{StaticResource RojoMarca}"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20,20,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-4" Radius="10" Opacity="0.15"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  Padding="20,14,20,20"
                  ColumnSpacing="16"
                  RowSpacing="6">

                <StackLayout Orientation="Horizontal" Spacing="6">
                    <Label Text="Pedidos:"
                           FontFamily="Nunito"
                           FontSize="13"
                           TextColor="#FFFFFFBB"
                           VerticalOptions="Center"/>
                    <Label Text="{Binding TotalPedidos}"
                           FontFamily="Nunito_bold"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </StackLayout>

                <StackLayout Grid.Column="1"
                             Orientation="Horizontal"
                             Spacing="6"
                             HorizontalOptions="End">
                    <Label Text="TOTAL:"
                           FontFamily="Nunito_bold"
                           FontSize="13"
                           TextColor="#FFFFFFBB"
                           VerticalOptions="Center"/>
                    <Label Text="{Binding Total, StringFormat='{0:N2}€'}"
                           FontFamily="Nunito_bold"
                           FontSize="17"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </StackLayout>

                <StackLayout Grid.Row="1"
                             Orientation="Horizontal"
                             Spacing="6">
                    <Label Text="T.Pedidos:"
                           FontFamily="Nunito"
                           FontSize="12"
                           TextColor="#FFFFFFAA"
                           VerticalOptions="Center"/>
                    <Label Text="{Binding TotalPedidosE, StringFormat='{0:N2}€'}"
                           FontFamily="Nunito_bold"
                           FontSize="13"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </StackLayout>

                <StackLayout Grid.Row="1"
                             Grid.Column="1"
                             Orientation="Horizontal"
                             Spacing="6"
                             HorizontalOptions="End">
                    <Label Text="T.Gastos:"
                           FontFamily="Nunito"
                           FontSize="12"
                           TextColor="#FFFFFFAA"
                           VerticalOptions="Center"/>
                    <Label Text="{Binding TotalGastos, StringFormat='{0:N2}€'}"
                           FontFamily="Nunito_bold"
                           FontSize="13"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </StackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
