<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Administrador.EnviarNotificacionView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ViewNotif"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Menú -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Image Source="menu.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Notificaciones"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Espaciador -->
                <BoxView Grid.Column="2" WidthRequest="44" Color="White"/>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <ScrollView Grid.Row="1" Padding="16,12">
            <StackLayout Spacing="16">

                <!-- ============================================ -->
                <!-- CARD: FILTROS DE DESTINATARIOS -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">
                        <Label Text="Filtros de destinatarios"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <!-- Nombre -->
                        <StackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label Text="Nombre"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E0E0E0"
                                        Padding="10,6">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Picker FontFamily="Nunito"
                                            FontSize="13"
                                            TextColor="{DynamicResource Negro}"
                                            ItemsSource="{Binding OpcionesTexto}"
                                            SelectedItem="{Binding Path=BindingContext.OpcionNombre, Source={x:Reference Name=ViewNotif}}"
                                            WidthRequest="120"/>
                                </Border>
                            </Grid>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    Padding="14,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Nombre}"
                                       FontFamily="Nunito"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="Nombre"/>
                            </Border>
                        </StackLayout>

                        <!-- Apellidos -->
                        <StackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label Text="Apellidos"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E0E0E0"
                                        Padding="10,6">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Picker FontFamily="Nunito"
                                            FontSize="13"
                                            TextColor="{DynamicResource Negro}"
                                            ItemsSource="{Binding OpcionesTexto}"
                                            SelectedItem="{Binding Path=BindingContext.OpcionApellidos, Source={x:Reference Name=ViewNotif}}"
                                            WidthRequest="120"/>
                                </Border>
                            </Grid>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    Padding="14,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Apellidos}"
                                       FontFamily="Nunito"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Placeholder="Apellidos"/>
                            </Border>
                        </StackLayout>

                        <!-- Email -->
                        <StackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <Label Text="Email"
                                       FontFamily="Nunito"
                                       FontSize="13"
                                       TextColor="#888888"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        BackgroundColor="#FAFAFA"
                                        StrokeThickness="1"
                                        Stroke="#E0E0E0"
                                        Padding="10,6">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Picker FontFamily="Nunito"
                                            FontSize="13"
                                            TextColor="{DynamicResource Negro}"
                                            ItemsSource="{Binding OpcionesTexto}"
                                            SelectedItem="{Binding Path=BindingContext.OpcionEmail, Source={x:Reference Name=ViewNotif}}"
                                            WidthRequest="120"/>
                                </Border>
                            </Grid>
                            <Border BackgroundColor="#FAFAFA"
                                    StrokeThickness="1"
                                    Stroke="#E0E0E0"
                                    Padding="14,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry Text="{Binding Email}"
                                       FontFamily="Nunito"
                                       FontSize="15"
                                       TextColor="{DynamicResource Negro}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Email"
                                       Placeholder="email@ejemplo.com"/>
                            </Border>
                        </StackLayout>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: SISTEMA OPERATIVO -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">
                        <Label Text="Sistema Operativo"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <!-- Todos -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#F5F5F5"
                                    StrokeThickness="0"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <StackLayout Spacing="8" HorizontalOptions="Center">
                                    <CheckBox IsChecked="{Binding SOTodos}"
                                              Color="{StaticResource RojoMarca}"
                                              HorizontalOptions="Center"/>
                                    <Label Text="Todos"
                                           FontFamily="Nunito"
                                           FontSize="13"
                                           TextColor="{DynamicResource Negro}"
                                           HorizontalTextAlignment="Center"/>
                                </StackLayout>
                            </Border>

                            <!-- Android -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#F5F5F5"
                                    StrokeThickness="0"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <StackLayout Spacing="8" HorizontalOptions="Center">
                                    <CheckBox IsChecked="{Binding Android}"
                                              Color="{StaticResource RojoMarca}"
                                              HorizontalOptions="Center"/>
                                    <Label Text="Android"
                                           FontFamily="Nunito"
                                           FontSize="13"
                                           TextColor="{DynamicResource Negro}"
                                           HorizontalTextAlignment="Center"/>
                                </StackLayout>
                            </Border>

                            <!-- iOS -->
                            <Border Grid.Column="2"
                                    BackgroundColor="#F5F5F5"
                                    StrokeThickness="0"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <StackLayout Spacing="8" HorizontalOptions="Center">
                                    <CheckBox IsChecked="{Binding IOS}"
                                              Color="{StaticResource RojoMarca}"
                                              HorizontalOptions="Center"/>
                                    <Label Text="iOS"
                                           FontFamily="Nunito"
                                           FontSize="13"
                                           TextColor="{DynamicResource Negro}"
                                           HorizontalTextAlignment="Center"/>
                                </StackLayout>
                            </Border>
                        </Grid>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- CARD: MENSAJE -->
                <!-- ============================================ -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout Spacing="16">
                        <Label Text="Mensaje"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="{DynamicResource Negro}"/>

                        <Border BackgroundColor="#FAFAFA"
                                StrokeThickness="1"
                                Stroke="#E0E0E0"
                                Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Editor Text="{Binding Cuerpo}"
                                    FontFamily="Nunito"
                                    FontSize="15"
                                    TextColor="{DynamicResource Negro}"
                                    BackgroundColor="Transparent"
                                    Placeholder="Escribe el mensaje de la notificación..."
                                    HeightRequest="150"
                                    AutoSize="TextChanges"/>
                        </Border>
                    </StackLayout>
                </Border>

                <!-- ============================================ -->
                <!-- BOTÓN ENVIAR -->
                <!-- ============================================ -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        Padding="18"
                        Margin="0,8,0,0"
                        HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" HorizontalOptions="Center">
                        <Image Grid.Column="0"
                               Source="notificacion.png"
                               WidthRequest="22"
                               HeightRequest="22"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Enviar notificación"
                               FontFamily="Nunito_bold"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding cmdEmail}"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Espaciado final -->
                

            </StackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
