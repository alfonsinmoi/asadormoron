<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AsadorMoron.Views.Administrador.RepartidoresView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ff="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    x:Name="ViewRepartidores"
    NavigationPage.HasNavigationBar="False"
    NavigationPage.HasBackButton="False"
    BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="RojoMarca">#C41E3A</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ============================================ -->
        <!-- HEADER FIJO -->
        <!-- ============================================ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.1"/>
            </Border.Shadow>
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Botón Menú -->
                <Border BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Image Source="menu.png"
                           WidthRequest="22"
                           HeightRequest="22"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMenuTapped"/>
                    </Border.GestureRecognizers>
                </Border>

                <!-- Título -->
                <Label Grid.Column="1"
                       Text="Repartidores"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="{DynamicResource Negro}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>

                <!-- Botón Añadir -->
                <Border Grid.Column="2"
                        BackgroundColor="{StaticResource RojoMarca}"
                        StrokeThickness="0"
                        WidthRequest="44"
                        HeightRequest="44">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource RojoMarca}" Offset="0,2" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Label Text="+"
                           FontSize="26"
                           FontFamily="Nunito_bold"
                           TextColor="White"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NuevoRepartidorCommand}"/>
                    </Border.GestureRecognizers>
                </Border>

            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- CONTENIDO PRINCIPAL -->
        <!-- ============================================ -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding ListadoRepartidores}"
                        SelectionMode="Single"
                        SelectedItem="{Binding RepartidorSeleccionado, Mode=TwoWay}"
                        Margin="16,12,16,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="12,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="10" Opacity="0.08"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">

                            <!-- Foto -->
                            <Border Grid.Column="0"
                                    StrokeThickness="0"
                                    WidthRequest="50"
                                    HeightRequest="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="25"/>
                                </Border.StrokeShape>
                                <ff:CachedImage Source="{Binding foto}"
                                                Aspect="AspectFill"
                                                WidthRequest="50"
                                                HeightRequest="50"
                                                DownsampleToViewSize="True"
                                                LoadingPlaceholder="usuario.png"
                                                ErrorPlaceholder="usuario.png"/>
                            </Border>

                            <!-- Nombre -->
                            <Label Grid.Column="1"
                                   Text="{Binding nombre}"
                                   FontFamily="Nunito_bold"
                                   FontSize="15"
                                   TextColor="{DynamicResource Negro}"
                                   VerticalOptions="Center"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"/>

                            <!-- Estado Switch -->
                            <Switch Grid.Column="2"
                                    IsToggled="{Binding activo}"
                                    IsEnabled="False"
                                    OnColor="{StaticResource RojoMarca}"
                                    VerticalOptions="Center"/>

                            <!-- Botón Eliminar -->
                            <Border Grid.Column="3"
                                    BackgroundColor="#FFEBEE"
                                    StrokeThickness="0"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Image Source="eliminar.png"
                                       WidthRequest="18"
                                       HeightRequest="18"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Path=BindingContext.EliminarRepartidorCommand, Source={x:Reference Name=ViewRepartidores}}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                            </Border>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Margin="0,20"
                        Padding="40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <StackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                        <Border BackgroundColor="#F5F5F5"
                                StrokeThickness="0"
                                Padding="16"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="30"/>
                            </Border.StrokeShape>
                            <Image Source="usuario.png"
                                   WidthRequest="32"
                                   HeightRequest="32"
                                   Opacity="0.5"/>
                        </Border>
                        <Label Text="Sin repartidores"
                               TextColor="{DynamicResource Negro}"
                               FontFamily="Nunito_bold"
                               FontSize="18"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Pulsa + para añadir uno nuevo"
                               TextColor="#888888"
                               FontFamily="Nunito"
                               FontSize="14"
                               HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Border>
            </CollectionView.EmptyView>

            <CollectionView.Footer>
                
            </CollectionView.Footer>
        </CollectionView>

    </Grid>

</ContentPage>
