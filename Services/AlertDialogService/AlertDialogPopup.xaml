<?xml version="1.0" encoding="utf-8" ?>
<rx:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
              xmlns:rx="clr-namespace:Mopups.Pages;assembly=Mopups"
              xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              x:Class="AsadorMoron.Services.AlertDialogService.AlertDialogPopup"
              BackgroundColor="#80000000">

    <Border x:Name="FrContent"
            BackgroundColor="White"
            StrokeThickness="0"
            Margin="32"
            Padding="24"
            HorizontalOptions="Fill"
            VerticalOptions="Center"
            Opacity="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24"/>
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#40000000" Offset="0,8" Radius="24" Opacity="0.3"/>
        </Border.Shadow>

        <Grid x:Name="GrContent"
              RowDefinitions="Auto,Auto,Auto"
              RowSpacing="16"
              HorizontalOptions="Fill"
              VerticalOptions="Center">

            <!-- Icono y Título -->
            <StackLayout Grid.Row="0" Spacing="12">
                <Border BackgroundColor="#FFF5F5"
                        StrokeThickness="0"
                        WidthRequest="56"
                        HeightRequest="56"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Label Text="&#x2139;"
                           FontSize="24"
                           TextColor="#C41E3A"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label x:Name="LbTitle"
                       FontFamily="Nunito_bold"
                       FontSize="20"
                       TextColor="#333333"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <!-- Mensaje -->
            <Label x:Name="LbMessage"
                   Grid.Row="1"
                   FontFamily="Nunito"
                   FontSize="15"
                   TextColor="#666666"
                   LineHeight="1.4"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Fill"
                   VerticalOptions="Start"/>

            <!-- Botones -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,8,0,0">

                <!-- Botón Cancelar -->
                <Border x:Name="BorderCancel"
                        Grid.Column="0"
                        BackgroundColor="#F5F5F5"
                        StrokeThickness="0"
                        HeightRequest="48"
                        HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BtCancel_Clicked"/>
                    </Border.GestureRecognizers>
                    <Label x:Name="BtCancel"
                           FontFamily="Nunito_bold"
                           FontSize="15"
                           TextColor="#666666"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Botón OK -->
                <Border x:Name="BorderOk"
                        Grid.Column="1"
                        BackgroundColor="#C41E3A"
                        StrokeThickness="0"
                        HeightRequest="48"
                        HorizontalOptions="Fill">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#40C41E3A" Offset="0,4" Radius="8" Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="BtOk_Clicked"/>
                    </Border.GestureRecognizers>
                    <Label x:Name="BtOk"
                           FontFamily="Nunito_bold"
                           FontSize="15"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</rx:PopupPage>
