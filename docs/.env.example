# /etc/qoorder/.env — copia a /etc/qoorder/.env y chmod 600
# NUNCA commitear el .env real. Solo este .example.

# ──── Backend ────────────────────────────────────────────────
APP_URL=https://qoorder.com
WEBHOOK_BASE_URL=https://agente.qoorder.com/webhook
APP_ENV=production

# ──── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ──── Vapi ───────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_ASSISTANT_ID=

# ──── Twilio ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+34...

# ──── ElevenLabs ─────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ──── Deepgram (opcional, suele venir con Vapi) ──────────────
DEEPGRAM_API_KEY=

# ──── Redis ──────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ──── Base de datos (ya existente, referencia) ───────────────
DB_HOST=localhost
DB_USER=pollo_user
DB_PASS=
DB_NAME=pollo

# ──── RGPD ───────────────────────────────────────────────────
RETENTION_AUDIO_DIAS=90
RETENTION_TRANSCRIPCION_DIAS=365

# ──── Límites operativos ─────────────────────────────────────
PRESUPUESTO_DIARIO_EUR=50
MAX_LLAMADAS_HORA_POR_NUMERO=3
MAX_IMPORTE_SIN_CONFIRMACION_HUMANA=100
MODO_SATURACION_UMBRAL=10

# ──── Concurrencia ───────────────────────────────────────────
PHP_FPM_WORKERS=30
DB_POOL_MIN=20
DB_POOL_MAX=50

# ──── Geocoding (validar zona) ───────────────────────────────
GOOGLE_MAPS_API_KEY=
# o alternativa gratuita:
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ──── Alertas operativas ─────────────────────────────────────
ALERTA_EMAIL=
ALERTA_SLACK_WEBHOOK=
